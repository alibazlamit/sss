---
import Layout from "../layouts/Layout.astro";

// Import base path for proper navigation - ensure it ends with /
const baseUrl = import.meta.env.BASE_URL;
const base =
  baseUrl === "" ? "/" : baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";

const clients = [
  { logo: "Arabian-Centres.png", name: "Arabian Centres", sector: "Retail & Commercial" },
  { logo: "Carrefour Saudi Arabia.png", name: "Carrefour Saudi Arabia", sector: "Retail & Hypermarket" },
  { logo: "Ascott.jpg", name: "Ascott", sector: "Hospitality & Hotels" },
  { logo: "STC-01.svg", name: "STC", sector: "Telecommunications" },
  { logo: "dallah.jpg", name: "Dallah", sector: "Healthcare & Medical" },
  { logo: "Nahdi.png", name: "Nahdi Pharmacy", sector: "Healthcare & Pharmacy" },
  { logo: "Regus.png", name: "Regus", sector: "Business Centers" },
  { logo: "Spaces.png", name: "Spaces", sector: "Co-working Spaces" },
  { logo: "riyad municipilit.png", name: "Riyadh Municipality", sector: "Government & Public" },
  { logo: "ministry-of-environment-water-agriculture-logo-png_seeklogo-335808.png", name: "Ministry of Environment", sector: "Government & Environment" },
  { logo: "Kkia-logo.jpg", name: "KIA Motors", sector: "Automotive" },
  { logo: "SAMT.png", name: "SAMT", sector: "Technology & Services" },
  { logo: "Color Motion.png", name: "Color Motion", sector: "Creative & Design" },
  { logo: "BLENDS.png", name: "Blends", sector: "Food & Beverage" },
  { logo: "Falla.png", name: "Falla", sector: "Food & Restaurants" },
  { logo: "37_logo~v~signature-juices.jpg", name: "Signature Juices", sector: "Food & Beverage" },
];

// Two marquee rows (split for opposite-direction scroll)
const marqueeTop = clients.slice(0, 8);
const marqueeBottom = clients.slice(8);

const testimonials = [
  {
    text: "SSS Security transformed our retail security with a comprehensive CCTV and access control system. Their professional approach and reliable service have exceeded our expectations.",
    name: "Mohammed Al-Rashid",
    role: "Security Manager, Arabian Centres",
  },
  {
    text: "Outstanding wireless security network installation across our entire chain. The 24/7 support and monitoring capabilities are invaluable for our operations.",
    name: "Sarah Al-Mahmoud",
    role: "Operations Director, Carrefour Saudi",
  },
  {
    text: "The smart home automation and security integration for our hospitality properties exceeded expectations. Seamless technology with exceptional results.",
    name: "Ahmed Al-Fahad",
    role: "Property Manager, Ascott",
  },
];
---

<Layout title="Our Clients - SSS Security Solutions">
  <!-- Clients Hero Section -->
  <section class="clients-hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">our valued clients</h1>
        <p class="hero-subtitle">
          Trusted partnerships built on excellence, security, and reliability.
          We're proud to serve leading organizations across various industries.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Band -->
  <section class="client-stats">
    <div class="container">
      <div class="client-stats-grid">
        <div class="client-stat">
          <span class="stat-number">16+</span>
          <span class="stat-caption">trusted clients</span>
        </div>
        <div class="client-stat">
          <span class="stat-number">8</span>
          <span class="stat-caption">industries served</span>
        </div>
        <div class="client-stat">
          <span class="stat-number">500+</span>
          <span class="stat-caption">installations</span>
        </div>
        <div class="client-stat">
          <span class="stat-number">100%</span>
          <span class="stat-caption">commitment</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Marquee -->
  <section class="logo-marquee-section">
    <div class="container">
      <p class="marquee-label">trusted across the kingdom</p>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {
          [...marqueeTop, ...marqueeTop].map((c) => (
            <div class="marquee-item">
              <img
                loading="lazy"
                decoding="async"
                src={`${base}images/clients/${c.logo}`}
                alt={c.name}
                onerror="this.style.display='none'"
              />
            </div>
          ))
        }
      </div>
    </div>
    <div class="marquee marquee-reverse" aria-hidden="true">
      <div class="marquee-track">
        {
          [...marqueeBottom, ...marqueeBottom].map((c) => (
            <div class="marquee-item">
              <img
                loading="lazy"
                decoding="async"
                src={`${base}images/clients/${c.logo}`}
                alt={c.name}
                onerror="this.style.display='none'"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Clients Grid Section -->
  <section class="clients-showcase">
    <div class="container">
      <h2 class="section-title">organizations that trust us</h2>
      <div class="clients-grid">
        {
          clients.map((c) => (
            <div class="client-item">
              <div class="client-logo">
                <img
                  loading="lazy"
                  decoding="async"
                  src={`${base}images/clients/${c.logo}`}
                  alt={c.name}
                  onerror="this.style.display='none'"
                />
              </div>
              <div class="client-info">
                <h3 class="client-name">{c.name}</h3>
                <p class="client-sector">{c.sector}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials Carousel -->
  <section class="testimonials">
    <div class="container">
      <h2 class="section-title">what our clients say</h2>
      <div class="testimonial-carousel" id="testimonialCarousel">
        <div class="testimonial-viewport">
          <div class="testimonial-track" id="testimonialTrack">
            {
              testimonials.map((t) => (
                <div class="testimonial-slide">
                  <div class="testimonial-card">
                    <span class="quote-mark">&ldquo;</span>
                    <div class="rating">
                      <span class="star">★</span><span class="star">★</span
                      ><span class="star">★</span><span class="star">★</span
                      ><span class="star">★</span>
                    </div>
                    <p class="testimonial-text">{t.text}</p>
                    <div class="testimonial-author">
                      <div class="author-avatar">{t.name.charAt(0)}</div>
                      <div class="author-meta">
                        <h4>{t.name}</h4>
                        <span>{t.role}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="testimonial-controls">
          <button class="tc-btn tc-prev" aria-label="Previous testimonial"
            >&#8249;</button
          >
          <div class="tc-dots" id="tcDots"></div>
          <button class="tc-btn tc-next" aria-label="Next testimonial"
            >&#8250;</button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="contact-cta">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">ready to join our trusted clients?</h2>
        <p class="cta-text">
          Contact us today for a free consultation and discover how our security
          solutions can protect your business.
        </p>
        <a href={`${base}contact`} class="cta-button">get free consultation</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Common Styles */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 300;
    text-transform: lowercase;
    letter-spacing: -1px;
    text-align: center;
    margin-bottom: 3rem;
    color: #334155;
  }

  /* Clients Hero */
  .clients-hero {
    height: 60vh;
    padding: 120px 0 80px;
    background:
      linear-gradient(
        180deg,
        rgba(11, 31, 51, 0.8) 0%,
        rgba(11, 31, 51, 0.64) 100%
      ),
      linear-gradient(
        115deg,
        rgba(0, 173, 231, 0.25) 0%,
        rgba(26, 54, 93, 0.35) 100%
      ),
      url("/images/upgrade/clients-hero.jpg") center center / cover no-repeat;
    color: #fff;
    text-align: center;
  }

  .hero-title {
    font-size: 4rem;
    font-weight: 200;
    color: #fff;
    margin-bottom: 2rem;
    text-transform: lowercase;
    letter-spacing: -1px;
    line-height: 1.1;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-size: 1.3rem;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.9;
  }

  /* Stats Band */
  .client-stats {
    background: linear-gradient(120deg, #00ade7 0%, #3fb7e9 100%);
    padding: 3rem 0;
  }

  .client-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .client-stat {
    position: relative;
    color: #fff;
  }

  .client-stat:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    height: 50px;
    width: 1px;
    background: rgba(255, 255, 255, 0.35);
  }

  .client-stat .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
  }

  .stat-caption {
    font-size: 0.95rem;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    opacity: 0.92;
  }

  /* Logo Marquee */
  .logo-marquee-section {
    padding: 4rem 0 3rem;
    background: #fff;
    overflow: hidden;
  }

  .marquee-label {
    text-align: center;
    text-transform: lowercase;
    letter-spacing: 3px;
    color: #94a3b8;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 2.5rem;
  }

  .marquee {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .marquee + .marquee {
    margin-top: 1.5rem;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: marqueeScroll 38s linear infinite;
  }

  .marquee-reverse .marquee-track {
    animation-direction: reverse;
    animation-duration: 46s;
  }

  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marqueeScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .marquee-item {
    flex: 0 0 auto;
    width: 150px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .marquee-item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.55);
    transition: filter 0.35s ease;
  }

  .marquee-item:hover img {
    filter: grayscale(0%) opacity(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }

  /* Clients Grid */
  .clients-showcase {
    padding: 80px 0;
    background: #f8fafc;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .client-item {
    position: relative;
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(15, 31, 51, 0.06);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
    border: 1px solid #e8eef3;
    overflow: hidden;
  }

  .client-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #00ade7, #3fb7e9);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .client-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(0, 173, 231, 0.16);
    border-color: #bfe9f8;
  }

  .client-item:hover::before {
    transform: scaleX(1);
  }

  .client-logo {
    width: 160px;
    height: 110px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
    border-radius: 15px;
    padding: 1.2rem;
    border: 1px solid #e8eef3;
    transition: all 0.35s ease;
  }

  .client-item:hover .client-logo {
    background: #fff;
    border-color: #bfe9f8;
    transform: scale(1.04);
  }

  .client-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(60%) opacity(0.8);
    transition: filter 0.35s ease;
  }

  .client-item:hover .client-logo img {
    filter: grayscale(0%) opacity(1);
  }

  .client-name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: #1a365d;
  }

  .client-sector {
    color: #00ade7;
    font-weight: 500;
    font-size: 0.9rem;
    text-transform: lowercase;
    letter-spacing: 0.5px;
  }

  /* Testimonials */
  .testimonials {
    padding: 90px 0;
    background:
      radial-gradient(
        circle at 15% 20%,
        rgba(0, 173, 231, 0.07),
        transparent 45%
      ),
      #fff;
  }

  .testimonials .section-title {
    color: #334155;
  }

  .testimonial-carousel {
    max-width: 820px;
    margin: 0 auto;
  }

  .testimonial-viewport {
    overflow: hidden;
    border-radius: 24px;
  }

  .testimonial-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.22, 0.7, 0.2, 1);
  }

  .testimonial-slide {
    flex: 0 0 100%;
    padding: 0.5rem;
  }

  .testimonial-card {
    position: relative;
    background: #fff;
    padding: 3.5rem 3rem 2.5rem;
    border-radius: 24px;
    border: 1px solid #e6eef4;
    box-shadow: 0 20px 50px rgba(15, 31, 51, 0.08);
    overflow: hidden;
  }

  .testimonial-card::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
    background: linear-gradient(180deg, #00ade7, #3fb7e9);
  }

  .quote-mark {
    position: absolute;
    top: 0.5rem;
    right: 2rem;
    font-size: 7rem;
    line-height: 1;
    font-family: Georgia, "Times New Roman", serif;
    color: rgba(0, 173, 231, 0.14);
    pointer-events: none;
  }

  .rating {
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .star {
    color: #00ade7;
    font-size: 1.15rem;
    margin-right: 0.15rem;
  }

  .testimonial-text {
    font-size: 1.2rem;
    line-height: 1.75;
    color: #334155;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00ade7, #3fb7e9);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 0 6px 16px rgba(0, 173, 231, 0.3);
  }

  .author-meta h4 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    color: #1a365d;
  }

  .author-meta span {
    color: #00ade7;
    font-size: 0.88rem;
    font-weight: 500;
  }

  .testimonial-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .tc-btn {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 2px solid #cfe9f6;
    background: #fff;
    color: #00ade7;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tc-btn:hover {
    background: #00ade7;
    border-color: #00ade7;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 173, 231, 0.3);
  }

  .tc-dots {
    display: flex;
    gap: 0.6rem;
  }

  .tc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: #cbd5e1;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .tc-dot.active {
    background: #00ade7;
    width: 28px;
    border-radius: 5px;
  }

  /* Contact CTA */
  .contact-cta {
    padding: 80px 0;
    background: linear-gradient(135deg, #1a365d 0%, #00ade7 100%);
    color: #fff;
    text-align: center;
  }

  .cta-title {
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
    text-transform: lowercase;
    letter-spacing: -1px;
  }

  .cta-text {
    font-size: 1.2rem;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    opacity: 0.92;
  }

  .cta-button {
    display: inline-block;
    padding: 15px 40px;
    background: #fff;
    color: #00ade7;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: lowercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .client-stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 1rem;
    }
    .client-stat:nth-child(2)::after {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-subtitle {
      font-size: 1.1rem;
    }
    .section-title {
      font-size: 2rem;
    }
    .cta-title {
      font-size: 2rem;
    }
    .clients-grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.25rem;
    }
    .testimonial-card {
      padding: 2.5rem 1.5rem 2rem;
    }
    .testimonial-text {
      font-size: 1.05rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }
    .section-title {
      font-size: 1.5rem;
    }
    .cta-title {
      font-size: 1.5rem;
    }
    .client-stat .stat-number {
      font-size: 2.2rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousel = document.getElementById("testimonialCarousel");
    if (!carousel) return;
    const track = document.getElementById("testimonialTrack");
    const slides = Array.from(track.children);
    const dotsWrap = document.getElementById("tcDots");
    const prev = carousel.querySelector(".tc-prev");
    const next = carousel.querySelector(".tc-next");
    let index = 0;
    let timer = null;

    // Build dots
    slides.forEach((_, i) => {
      const dot = document.createElement("button");
      dot.className = "tc-dot" + (i === 0 ? " active" : "");
      dot.setAttribute("aria-label", "Go to testimonial " + (i + 1));
      dot.addEventListener("click", () => go(i));
      dotsWrap.appendChild(dot);
    });
    const dots = Array.from(dotsWrap.children);

    function render() {
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle("active", i === index));
    }
    function go(i) {
      index = (i + slides.length) % slides.length;
      render();
      restart();
    }
    function restart() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => go(index + 1), 6000);
    }

    prev.addEventListener("click", () => go(index - 1));
    next.addEventListener("click", () => go(index + 1));

    // Pause auto-play on hover
    carousel.addEventListener("mouseenter", () => timer && clearInterval(timer));
    carousel.addEventListener("mouseleave", restart);

    restart();
  });
</script>
