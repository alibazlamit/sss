---
import Layout from "../layouts/Layout.astro";

// Base path (ends with /)
const baseUrl = import.meta.env.BASE_URL;
const base =
  baseUrl === "" ? "/" : baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";

const f = (folder: string, name: string) =>
  `${base}projects/${folder}/${name}`;

// Cinematic portfolio reel. Client + sector + scope lead; treated imagery supports.
// Scope copy drafted from project type — confirm exact systems with client.
const projects = [
  {
    id: "kkia",
    code: "KKIA-T1",
    sector: "Government",
    location: "Terminal 1 · Riyadh",
    title: "King Khalid<br/>International Airport",
    blurb:
      "Fire-detection and structured-cabling backbone delivered across a live international terminal — engineered for uptime, code compliance and round-the-clock operation.",
    scope: ["Fire & Safety", "Structured Cabling"],
    cover: `${base}images/systems/kkia-terminal-enhanced.jpg`,
    folder: "King Khalid International Airport - Terminal 1 - Pic",
    images: [
      `${base}images/systems/kkia-terminal-enhanced.jpg`,
      `${base}images/kkia/terminal-systems.jpg`,
      `${base}images/kkia/fire-safety.jpg`,
      `${base}images/kkia/cabling-rack.jpg`,
      `${base}images/kkia/cabling-trays.jpg`,
    ],
  },
  {
    id: "citadines",
    code: "CITA-DXB",
    sector: "Hospitality",
    location: "Culture Village · Dubai",
    title: "Citadines<br/>Culture Village",
    blurb:
      "Integrated CCTV and smart-building systems for a waterfront hospitality landmark — discreet coverage that holds the guest experience intact.",
    scope: ["CCTV", "Smart Integration"],
    cover: f("Citadines Culture Village Dubai - Pic", "cover.jpg"),
    folder: "Citadines Culture Village Dubai - Pic",
    images: [
      f("Citadines Culture Village Dubai - Pic", "cover.jpg"),
      `${base}images/ai-projects/citadines-cctv.jpg`,
      `${base}images/ai-projects/citadines-access.jpg`,
      `${base}images/ai-projects/citadines-bms.jpg`,
    ],
  },
  {
    id: "learning-oasis",
    code: "OASIS-EDU",
    sector: "Education",
    location: "Riyadh",
    title: "Learning Oasis<br/>National School",
    blurb:
      "End-to-end campus security — surveillance and access control mapped across classrooms, corridors and entry points to keep a busy school safe.",
    scope: ["CCTV", "Access Control"],
    cover: `${base}images/projects/learning_oasis_int_schools_cover.jpg`,
    folder: "Learning Oasis National International School - Pic",
    images: [
      `${base}images/projects/learning_oasis_int_schools_cover.jpg`,
      `${base}images/ai-projects/oasis-corridor.jpg`,
      `${base}images/ai-projects/oasis-entrance.jpg`,
      `${base}images/ai-projects/oasis-monitoring.jpg`,
    ],
  },
  {
    id: "dallah",
    code: "DLH-RYD",
    sector: "Healthcare",
    location: "Basement Parking · Riyadh",
    title: "Dallah<br/>Rafa Clinic",
    blurb:
      "Surveillance and access control for a clinic basement-parking renovation — controlled entry and full visual coverage in a sensitive healthcare setting.",
    scope: ["CCTV", "Access Control"],
    cover: f("Dallah Rafa Clinic Basement Parking Renovation - Pic", "cover.jpg"),
    folder: "Dallah Rafa Clinic Basement Parking Renovation - Pic",
    images: [
      f("Dallah Rafa Clinic Basement Parking Renovation - Pic", "cover.jpg"),
      `${base}images/ai-projects/dallah-parking-cctv.jpg`,
      `${base}images/ai-projects/dallah-barrier.jpg`,
      `${base}images/ai-projects/dallah-entrance.jpg`,
    ],
  },
  {
    id: "spaces",
    code: "SPCS-RP",
    sector: "Corporate",
    location: "Riyadh Park",
    title: "SPACES<br/>by Regus",
    blurb:
      "CCTV and access control for a premium serviced-office floor — clean, unobtrusive security that matches a high-end corporate environment.",
    scope: ["CCTV", "Access Control"],
    cover: f("Serviced Office - SPACES - by Regus at Riyadh Park - Pic", "cover.jpg"),
    folder: "Serviced Office - SPACES - by Regus at Riyadh Park - Pic",
    images: [
      f("Serviced Office - SPACES - by Regus at Riyadh Park - Pic", "cover.jpg"),
      `${base}images/ai-projects/spaces-cctv.jpg`,
      `${base}images/ai-projects/spaces-access.jpg`,
      `${base}images/ai-projects/spaces-reception.jpg`,
    ],
  },
  {
    id: "p2p",
    code: "P2P-LINK",
    sector: "Networking",
    location: "Long-distance bridging",
    title: "Point-to-Point<br/>Wireless Link",
    blurb:
      "Long-range point-to-point wireless bridging between distant sites — a licensed, line-of-sight backbone delivering stable connectivity without trenching.",
    scope: ["Wireless", "Connectivity"],
    cover: `${base}images/ai-projects/p2p-antenna.jpg`,
    folder: "Point to Point Wireless Connection Project - Pic",
    images: [
      `${base}images/ai-projects/p2p-antenna.jpg`,
      `${base}images/ai-projects/p2p-rooftop.jpg`,
      `${base}images/ai-projects/p2p-tower.jpg`,
      `${base}images/ai-projects/p2p-install.jpg`,
    ],
  },
];
---

<Layout title="Projects — SSS Security Solutions">
  <main class="reel">
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
      <div class="hero-inner">
        <span class="kicker">SSS · selected work</span>
        <h1>Projects engineered<br /><em>to operate at scale.</em></h1>
        <p class="hero-sub">
          A reel of delivered security &amp; telecom integrations — from a live
          international airport to clinics, schools and corporate floors across
          the Kingdom and the Gulf.
        </p>
        <div class="hero-stats">
          <div><b>6</b><span>flagship projects</span></div>
          <div><b>5</b><span>sectors served</span></div>
          <div><b>KSA + UAE</b><span>delivery footprint</span></div>
        </div>
      </div>
      <span class="scrollcue">scroll ↓</span>
    </section>

    <!-- ============ INDEX RAIL ============ -->
    <nav class="rail" aria-label="Project index">
      {projects.map((p, i) => (
        <button class="rail-dot" data-jump={i} aria-label={p.title.replace(/<[^>]+>/g, " ")}>
          <span class="rail-no">{String(i + 1).padStart(2, "0")}</span>
          <span class="rail-tip">{p.sector}</span>
        </button>
      ))}
    </nav>

    <!-- ============ PROJECT PANELS ============ -->
    {projects.map((p, i) => (
      <section class={`panel ${i % 2 === 0 ? "left" : "right"}`} data-panel={i} id={`p-${p.id}`}>
        <div class="panel-bg" style={`background-image:url("${p.cover}")`}></div>
        <div class="panel-scrim"></div>
        <div class="panel-lines"></div>
        <span class="panel-badge"><span>CAM · {p.code}</span><i class="rec"></i>REC</span>

        <div class="panel-content">
          <span class="p-no">{String(i + 1).padStart(2, "0")} <em>/ 0{projects.length}</em></span>
          <span class="p-tag">{p.sector} · {p.location}</span>
          <h2 class="p-title" set:html={p.title}></h2>
          <p class="p-blurb">{p.blurb}</p>
          <div class="p-chips">
            {p.scope.map((s) => <span>{s}</span>)}
          </div>
          <button class="p-open" data-proj={p.id}>
            <span class="p-open-lbl">Open gallery</span>
            <span class="p-open-n">{p.images.length} photos</span>
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>
        </div>
      </section>
    ))}
  </main>

  <!-- ============ LIGHTBOX ============ -->
  <div class="lb" id="lb" aria-hidden="true">
    <div class="lb-scrim" id="lbScrim"></div>
    <div class="lb-panel">
      <div class="lb-head">
        <div class="lb-titles">
          <span class="lb-code" id="lbCode">CAM</span>
          <h3 id="lbTitle">Project</h3>
          <p id="lbMeta">meta</p>
        </div>
        <div class="lb-chips" id="lbScope"></div>
        <button class="lb-x" id="lbX" aria-label="Close gallery">✕</button>
      </div>
      <div class="lb-stage">
        <button class="lb-nav lb-prev" id="lbPrev" aria-label="Previous">‹</button>
        <div class="lb-imgwrap">
          <img id="lbImg" src="" alt="" />
          <span class="lb-rec"><i></i>REC</span>
          <span class="lb-count" id="lbCount">1 / 1</span>
        </div>
        <button class="lb-nav lb-next" id="lbNext" aria-label="Next">›</button>
      </div>
      <div class="lb-thumbs" id="lbThumbs"></div>
    </div>
  </div>
</Layout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap");

  .reel {
    --cy: #00ade7;
    --cy2: #3fb7e9;
    --ink: #050d17;
    --ink2: #081726;
    --paper: #e8f2f9;
    --muted: #9db4c6;
    --mono: "JetBrains Mono", monospace;
    background: var(--ink);
    color: var(--paper);
    overflow-x: clip;
  }

  /* ===================== HERO ===================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem clamp(1.5rem, 7vw, 9rem) 4rem;
    overflow: hidden;
    background: var(--ink);
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 18% 8%, rgba(0, 173, 231, 0.22), transparent 60%),
      radial-gradient(ellipse 50% 60% at 95% 100%, rgba(63, 183, 233, 0.14), transparent 60%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 173, 231, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 173, 231, 0.06) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 30% 20%, #000, transparent 75%);
    mask-image: radial-gradient(ellipse 70% 70% at 30% 20%, #000, transparent 75%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 2; max-width: 880px; }
  .kicker {
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 5px;
    font-size: 0.74rem;
    color: var(--cy2);
    font-weight: 600;
  }
  .hero h1 {
    font-family: "Poppins", sans-serif;
    font-weight: 800;
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: -2px;
    margin: 1.3rem 0 0;
  }
  .hero h1 em {
    font-style: normal;
    color: transparent;
    background: linear-gradient(100deg, var(--cy), var(--cy2) 60%, #bfe9fb);
    -webkit-background-clip: text;
    background-clip: text;
  }
  .hero-sub {
    color: var(--muted);
    font-weight: 300;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.75;
    max-width: 620px;
    margin: 1.8rem 0 2.6rem;
  }
  .hero-stats { display: flex; flex-wrap: wrap; gap: clamp(1.5rem, 4vw, 3.4rem); }
  .hero-stats div { border-left: 2px solid rgba(0, 173, 231, 0.45); padding-left: 1rem; }
  .hero-stats b {
    display: block;
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1;
    color: #fff;
  }
  .hero-stats span {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--muted);
    margin-top: 0.4rem;
    display: block;
  }
  .scrollcue {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 2px;
    color: var(--muted);
    animation: bob 1.9s ease-in-out infinite;
  }
  @keyframes bob { 50% { transform: translate(-50%, 7px); } }

  /* ===================== INDEX RAIL ===================== */
  .rail {
    position: fixed;
    top: 50%;
    right: clamp(0.8rem, 2vw, 2rem);
    transform: translateY(-50%);
    z-index: 40;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .rail-dot {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.55rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem 0;
  }
  .rail-no {
    font-family: var(--mono);
    font-size: 0.66rem;
    color: rgba(157, 180, 198, 0.5);
    transition: color 0.25s;
  }
  .rail-dot::after {
    content: "";
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: rgba(157, 180, 198, 0.35);
    transition: all 0.25s;
  }
  .rail-dot:hover .rail-no,
  .rail-dot.active .rail-no { color: var(--cy2); }
  .rail-dot:hover::after,
  .rail-dot.active::after { background: var(--cy); width: 34px; box-shadow: 0 0 10px rgba(0, 173, 231, 0.7); }
  .rail-tip {
    position: absolute;
    right: 38px;
    font-family: var(--mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--cy2);
    background: rgba(5, 13, 23, 0.9);
    border: 1px solid rgba(0, 173, 231, 0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 5px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transform: translateX(6px);
    transition: 0.2s;
  }
  .rail-dot:hover .rail-tip { opacity: 1; transform: translateX(0); }

  /* ===================== PROJECT PANELS ===================== */
  .panel {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem clamp(1.5rem, 7vw, 9rem);
    overflow: hidden;
    isolation: isolate;
  }
  .panel.right { justify-content: flex-end; }
  .panel-bg {
    position: absolute;
    inset: -8% 0;
    z-index: -3;
    background-size: cover;
    background-position: center;
    filter: brightness(0.62) saturate(0.92) contrast(1.06);
    transform: scale(1.06);
    will-change: transform;
  }
  .panel-scrim {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, var(--ink) 2%, rgba(5, 13, 23, 0.82) 30%, rgba(5, 13, 23, 0.2) 62%, transparent 85%),
      linear-gradient(0deg, var(--ink), transparent 35%),
      linear-gradient(180deg, rgba(5, 13, 23, 0.6), transparent 25%);
  }
  .panel.right .panel-scrim {
    background:
      linear-gradient(270deg, var(--ink) 2%, rgba(5, 13, 23, 0.82) 30%, rgba(5, 13, 23, 0.2) 62%, transparent 85%),
      linear-gradient(0deg, var(--ink), transparent 35%),
      linear-gradient(180deg, rgba(5, 13, 23, 0.6), transparent 25%);
  }
  .panel-lines {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: repeating-linear-gradient(rgba(255, 255, 255, 0) 0 3px, rgba(0, 0, 0, 0.07) 3px 4px);
    pointer-events: none;
    opacity: 0.5;
  }
  .panel-badge {
    position: absolute;
    top: 2rem;
    z-index: 3;
    left: clamp(1.5rem, 7vw, 9rem);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 1px;
    color: #bfe3f5;
    text-shadow: 0 1px 4px #000;
  }
  .panel.right .panel-badge { left: auto; right: clamp(1.5rem, 7vw, 9rem); }
  .panel-badge .rec {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ff5a5a; margin-left: 0.4rem;
    animation: blink 1.4s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0.2; } }

  .panel-content { position: relative; z-index: 2; max-width: 540px; }
  .panel.right .panel-content { text-align: right; }
  .panel.right .p-chips { justify-content: flex-end; }
  .panel.right .p-open { margin-left: auto; }

  .p-no {
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--cy2);
    letter-spacing: 1px;
  }
  .p-no em { font-style: normal; color: rgba(157, 180, 198, 0.55); }
  .p-tag {
    display: block;
    font-family: var(--mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    margin: 1.1rem 0 0.7rem;
  }
  .p-title {
    font-family: "Poppins", sans-serif;
    font-weight: 800;
    font-size: clamp(2.3rem, 5.5vw, 4.4rem);
    line-height: 0.96;
    letter-spacing: -1.6px;
    margin: 0;
    text-shadow: 0 6px 40px rgba(0, 0, 0, 0.5);
  }
  .p-blurb {
    color: #cfe0ec;
    font-weight: 300;
    line-height: 1.7;
    margin: 1.4rem 0 1.6rem;
    font-size: clamp(0.96rem, 1.2vw, 1.08rem);
  }
  .p-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .p-chips span {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    color: #dff4fc;
    background: rgba(0, 173, 231, 0.13);
    border: 1px solid rgba(0, 173, 231, 0.4);
    backdrop-filter: blur(4px);
  }
  .p-open {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1.4rem;
    background: linear-gradient(120deg, var(--cy), var(--cy2));
    color: #04121d;
    border: none;
    border-radius: 10px;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.22s, box-shadow 0.22s;
    box-shadow: 0 8px 30px rgba(0, 173, 231, 0.32);
  }
  .p-open:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(0, 173, 231, 0.5); }
  .p-open-n {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.18rem 0.5rem;
    border-radius: 5px;
    background: rgba(4, 18, 29, 0.18);
  }
  .p-open svg { width: 18px; height: 18px; fill: none; stroke: #04121d; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.22s; }
  .p-open:hover svg { transform: translateX(4px); }

  /* ----- scroll-reveal staging ----- */
  .panel-content > * {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .panel.in .panel-content > * { opacity: 1; transform: none; }
  .panel.in .p-tag { transition-delay: 0.06s; }
  .panel.in .p-title { transition-delay: 0.12s; }
  .panel.in .p-blurb { transition-delay: 0.2s; }
  .panel.in .p-chips { transition-delay: 0.28s; }
  .panel.in .p-open { transition-delay: 0.36s; }
  .panel.in .panel-bg { animation: kenburns 14s ease-out forwards; }
  @keyframes kenburns { to { transform: scale(1.14); } }

  /* ===================== LIGHTBOX ===================== */
  .lb { position: fixed; inset: 0; z-index: 200; display: none; align-items: center; justify-content: center; padding: 2.5vh 2vw; }
  .lb.open { display: flex; }
  .lb-scrim { position: absolute; inset: 0; background: rgba(2, 7, 13, 0.92); backdrop-filter: blur(7px); }
  .lb-panel {
    position: relative; z-index: 2; width: min(1120px, 96vw); max-height: 95vh;
    display: flex; flex-direction: column; background: #060f1a;
    border: 1px solid rgba(0, 173, 231, 0.3); border-radius: 14px; overflow: hidden;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.7);
    animation: lbpop 0.3s cubic-bezier(0.2, 0.9, 0.3, 1.2);
  }
  @keyframes lbpop { from { opacity: 0; transform: scale(0.96) translateY(10px); } }
  .lb-head { display: flex; align-items: flex-start; gap: 1.2rem; padding: 1.1rem 1.3rem; border-bottom: 1px solid rgba(0, 173, 231, 0.18); }
  .lb-code { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 1px; color: #06121f; background: linear-gradient(120deg, var(--cy), var(--cy2)); padding: 0.22rem 0.55rem; border-radius: 5px; font-weight: 600; }
  .lb-titles h3 { font-family: "Poppins", sans-serif; font-size: 1.4rem; font-weight: 700; margin-top: 0.55rem; letter-spacing: -0.4px; color: #fff; }
  .lb-titles p { font-family: var(--mono); font-size: 0.7rem; color: #8fb6cf; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.2rem; }
  .lb-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-left: auto; align-self: center; }
  .lb-chips :global(span) { font-family: var(--mono); font-size: 0.7rem; padding: 0.3rem 0.7rem; border-radius: 6px; color: #dff4fc; background: rgba(0, 173, 231, 0.14); border: 1px solid rgba(0, 173, 231, 0.35); }
  .lb-x { flex: 0 0 auto; background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.14); color: #cfe9f6; width: 38px; height: 38px; border-radius: 9px; font-size: 1rem; cursor: pointer; transition: 0.2s; }
  .lb-x:hover { background: var(--cy); color: #06121f; border-color: var(--cy); }
  .lb-stage { position: relative; flex: 1; min-height: 0; display: flex; align-items: center; justify-content: center; gap: 0.4rem; background: #03080e; padding: 0.6rem; }
  .lb-imgwrap { position: relative; max-width: 100%; max-height: 64vh; display: flex; }
  .lb-imgwrap img { max-width: 100%; max-height: 64vh; object-fit: contain; border-radius: 6px; display: block; }
  .lb-rec { position: absolute; top: 0.7rem; left: 0.7rem; display: flex; align-items: center; gap: 0.3rem; font-family: var(--mono); font-size: 0.66rem; color: #ff6868; text-shadow: 0 1px 4px #000; }
  .lb-rec i { width: 7px; height: 7px; border-radius: 50%; background: #ff6868; animation: blink 1.4s steps(1) infinite; }
  .lb-count { position: absolute; bottom: 0.7rem; right: 0.7rem; font-family: var(--mono); font-size: 0.68rem; color: #bfe3f5; background: rgba(4, 10, 18, 0.7); padding: 0.2rem 0.5rem; border-radius: 5px; }
  .lb-nav { flex: 0 0 auto; background: rgba(0, 173, 231, 0.12); border: 1px solid rgba(0, 173, 231, 0.3); color: #dff4fc; width: 46px; height: 46px; border-radius: 50%; font-size: 1.6rem; line-height: 1; cursor: pointer; transition: 0.2s; }
  .lb-nav:hover { background: var(--cy); color: #06121f; }
  .lb-thumbs { display: flex; gap: 8px; padding: 0.9rem 1.1rem; overflow-x: auto; border-top: 1px solid rgba(0, 173, 231, 0.18); }
  .lb-thumbs :global(img) { height: 56px; width: 84px; object-fit: cover; border-radius: 5px; cursor: pointer; opacity: 0.5; border: 1px solid transparent; transition: 0.18s; flex: 0 0 auto; }
  .lb-thumbs :global(img:hover) { opacity: 0.85; }
  .lb-thumbs :global(img.active) { opacity: 1; border-color: var(--cy); box-shadow: 0 0 12px rgba(0, 173, 231, 0.5); }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 760px) {
    .rail { display: none; }
    .panel { padding: 5rem 1.5rem; align-items: flex-end; }
    .panel.right { justify-content: flex-start; }
    .panel.right .panel-content { text-align: left; }
    .panel.right .p-chips { justify-content: flex-start; }
    .panel.right .p-open { margin-left: 0; }
    .panel.right .panel-badge { left: 1.5rem; right: auto; }
    .panel-scrim,
    .panel.right .panel-scrim {
      background:
        linear-gradient(0deg, var(--ink) 6%, rgba(5, 13, 23, 0.55) 45%, rgba(5, 13, 23, 0.25) 100%);
    }
    .hero-stats div { border-left: none; border-top: 2px solid rgba(0, 173, 231, 0.45); padding: 0.8rem 0 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .panel-content > * { opacity: 1; transform: none; }
    .panel.in .panel-bg, .scrollcue { animation: none; }
  }
</style>

<script define:vars={{ projects }}>
  // ---- index lookup ----
  const byId = {};
  projects.forEach((p) => (byId[p.id] = p));

  // ---- scroll reveal + parallax + active rail ----
  const panels = [...document.querySelectorAll(".panel")];
  const dots = [...document.querySelectorAll(".rail-dot")];

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("in");
        const i = +e.target.dataset.panel;
        if (e.isIntersecting && e.intersectionRatio > 0.5) {
          dots.forEach((d, n) => d.classList.toggle("active", n === i));
        }
      });
    },
    { threshold: [0.25, 0.5, 0.75] }
  );
  panels.forEach((p) => io.observe(p));

  dots.forEach((d) =>
    d.addEventListener("click", () => {
      const t = panels[+d.dataset.jump];
      if (t) t.scrollIntoView({ behavior: "smooth" });
    })
  );

  let ticking = false;
  window.addEventListener("scroll", () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      panels.forEach((p) => {
        const bg = p.querySelector(".panel-bg");
        if (!bg) return;
        const r = p.getBoundingClientRect();
        if (r.bottom < 0 || r.top > window.innerHeight) return;
        const prog = (r.top + r.height / 2 - window.innerHeight / 2) / window.innerHeight;
        bg.style.transform = `scale(1.12) translateY(${prog * -36}px)`;
      });
      ticking = false;
    });
  });

  // ---- lightbox ----
  const lb = document.getElementById("lb");
  const lbImg = document.getElementById("lbImg");
  const lbThumbs = document.getElementById("lbThumbs");
  let cur = null, idx = 0;

  function show(i) {
    const g = byId[cur].images;
    idx = (i + g.length) % g.length;
    lbImg.src = g[idx];
    document.getElementById("lbCount").textContent = idx + 1 + " / " + g.length;
    [...lbThumbs.children].forEach((t, n) => t.classList.toggle("active", n === idx));
    const a = lbThumbs.children[idx];
    if (a) a.scrollIntoView({ block: "nearest", inline: "center" });
  }
  function open(key) {
    cur = key;
    const p = byId[key];
    document.getElementById("lbCode").textContent = "CAM · " + p.code;
    document.getElementById("lbTitle").textContent = p.title.replace(/<[^>]+>/g, " ").trim();
    document.getElementById("lbMeta").textContent = p.sector + " · " + p.location;
    document.getElementById("lbScope").innerHTML = p.scope.map((s) => "<span>" + s + "</span>").join("");
    lbThumbs.innerHTML = "";
    p.images.forEach((src, n) => {
      const im = document.createElement("img");
      im.src = src;
      im.loading = "lazy";
      im.addEventListener("click", () => show(n));
      lbThumbs.appendChild(im);
    });
    lb.classList.add("open");
    lb.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    show(0);
  }
  function close() {
    lb.classList.remove("open");
    lb.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.querySelectorAll(".p-open[data-proj]").forEach((b) =>
    b.addEventListener("click", () => open(b.getAttribute("data-proj")))
  );
  document.getElementById("lbX").addEventListener("click", close);
  document.getElementById("lbScrim").addEventListener("click", close);
  document.getElementById("lbPrev").addEventListener("click", () => show(idx - 1));
  document.getElementById("lbNext").addEventListener("click", () => show(idx + 1));
  document.addEventListener("keydown", (e) => {
    if (!lb.classList.contains("open")) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") show(idx - 1);
    if (e.key === "ArrowRight") show(idx + 1);
  });
</script>
