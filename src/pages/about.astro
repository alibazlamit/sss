---
import Layout from "../layouts/Layout.astro";

// Import base path for proper navigation - ensure it ends with /
const baseUrl = import.meta.env.BASE_URL;
const base =
  baseUrl === "" ? "/" : baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";
---

<Layout title="About SSS - Security System Solutions">
  <!-- About Hero -->
  <section class="about-hero">
    <div class="hero-content">
      <h1 class="hero-title">about sss</h1>
      <p class="hero-subtitle">
        security system solutions - professional installation and comprehensive
        security services
      </p>
    </div>
  </section>

  <!-- About Navigation -->
  <nav class="about-navigation">
    <div class="about-nav">
      <a href="#company-overview" class="about-nav-link active"
        >company overview</a
      >
      <a href="#company-structure" class="about-nav-link">company structure</a>
      <a href="#mission-vision" class="about-nav-link">mission & vision</a>
      <a href="#why-choose-us" class="about-nav-link">why choose us</a>
    </div>
  </nav>

  <!-- Company Overview Section -->
  <section id="company-overview" class="about-section">
    <div class="section-container">
      <h2 class="section-title">company overview</h2>
      <div class="overview-grid">
        <div class="overview-text">
          <p class="lead-text">
            SSS Security Systems is a leading provider of comprehensive security
            solutions, specializing in the design, installation, and maintenance
            of advanced security systems for residential and commercial
            properties.
          </p>

          <p>
            With years of experience in the security industry, we have built a
            reputation for delivering high-quality installations, innovative
            solutions, and exceptional customer service. Our team of certified
            professionals works with cutting-edge technology to ensure your
            property remains secure and protected.
          </p>

          <div class="key-stats">
            <div class="stat-item">
              <h3>500+</h3>
              <p>projects completed</p>
            </div>
            <div class="stat-item">
              <h3>200+</h3>
              <p>satisfied clients</p>
            </div>
            <div class="stat-item">
              <h3>24/7</h3>
              <p>support available</p>
            </div>
          </div>
        </div>
        <div class="overview-image">
          <img loading="lazy" decoding="async"
            src={`${base}images/upgrade/about-team.jpg`}
            alt="SSS Security Systems Team"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Tagline Band -->
  <section class="tagline-band">
    <div class="section-container">
      <blockquote class="brand-quote">
        <span class="quote-mark" aria-hidden="true">&ldquo;</span>
        we don&rsquo;t search for fast execution &mdash; we search for a system
        that lives and continues.
      </blockquote>
    </div>
  </section>

  <!-- Company Structure Section -->
  <section
    id="company-structure"
    class="about-section company-structure-section"
  >
    <div class="section-container">
      <h2 class="section-title">company structure</h2>
      <p class="section-subtitle">
        our organizational hierarchy and team structure
      </p>

      <div class="structure-container">
        <!-- Top Level - External Entities -->
        <div class="top-level">
          <div class="entity-box customer">
            <h3>customer / client</h3>
            <p>
              end users requiring comprehensive security solutions and
              professional installation services
            </p>
          </div>
          <div class="entity-box suppliers">
            <h3>suppliers</h3>
            <p>
              equipment vendors, technology partners, and component
              manufacturers providing quality materials
            </p>
          </div>
          <div class="entity-box sss">
            <h3>security system solution co.</h3>
            <p>
              core business entity delivering integrated security solutions and
              professional installation services
            </p>
          </div>
        </div>

        <!-- Division Manager -->
        <div class="division-manager">
          <div class="manager-box">
            <h3>division manager</h3>
            <ul>
              <li>strategic planning and oversight</li>
              <li>team coordination and management</li>
              <li>client relationship management</li>
              <li>business development initiatives</li>
              <li>quality assurance and compliance</li>
              <li>resource allocation and optimization</li>
            </ul>
          </div>
        </div>

        <!-- Department Structure -->
        <div class="departments-grid">
          <div class="department-box sales">
            <div class="department-header">sales team</div>
            <div class="department-content">
              <div class="department-title">sales engineer</div>
              <ul>
                <li>problem solving</li>
                <li>product knowledge</li>
                <li>selling to customer needs</li>
                <li>software requirements</li>
                <li>product development</li>
                <li>presentation skills</li>
                <li>technical understanding</li>
                <li>verbal communication</li>
                <li>requirements analysis</li>
                <li>innovation</li>
                <li>meets assigned sales targets</li>
                <li>business development</li>
                <li>due diligence of unsuccessful sales pitch</li>
              </ul>
            </div>
          </div>

          <div class="department-box pre-sales">
            <div class="department-header">pre-sales team</div>
            <div class="department-content">
              <div class="department-title">pre-sales engineer</div>
              <ul>
                <li>supports assigned deals</li>
                <li>prioritizing effort on team productivity and profit</li>
                <li>technical solution required</li>
                <li>address customer requirements</li>
                <li>assess customers' needs</li>
                <li>recommend solutions</li>
                <li>optimize value</li>
                <li>sales support</li>
                <li>product knowledge</li>
                <li>enhancement</li>
                <li>site surveys</li>
                <li>creates technical proposals</li>
                <li>prepares commercial proposals</li>
              </ul>
            </div>
          </div>

          <div class="department-box draftsman">
            <div class="department-header">draftsman</div>
            <div class="department-content">
              <div class="department-title">draftsman</div>
              <ul>
                <li>liaise with sales and pre-sales team</li>
                <li>quantity takeoff</li>
                <li>
                  prepare and review rough sketches and review with sales and
                  pre-sales team
                </li>
                <li>create detailed designs</li>
                <li>identify potential operational issues</li>
                <li>
                  ensure final designs comply with regulations and quality
                  standards
                </li>
                <li>create as-built drawings</li>
              </ul>
            </div>
          </div>

          <div class="department-box accounting">
            <div class="department-header">accounting</div>
            <div class="department-content">
              <div class="department-title">accountant</div>
              <ul>
                <li>weekly report</li>
                <li>payment follow-up with clients</li>
                <li>create pos</li>
                <li>create invoices</li>
                <li>prepare soa</li>
                <li>create supplier payment transfers</li>
                <li>follow-up on delivery</li>
                <li>follow-ups on payment refunds</li>
              </ul>
            </div>
          </div>

          <div class="department-box project-impl">
            <div class="department-header">project implementation team</div>
            <div class="department-content">
              <div class="department-title">site engineer</div>
              <ul>
                <li>service & maintenance</li>
                <li>repair faulty equipment units</li>
                <li>develop and implement preventive maintenance</li>
                <li>ensure proper installation of equipment/devices</li>
                <li>works with a variety of tools and equipment</li>
                <li>
                  climbs ladders, squats, bends, & stands on working hours
                </li>
                <li>completing installation; performing acceptance tests</li>
                <li>suggesting improved methods and techniques</li>
                <li>maintains rapport with customers</li>
                <li>completing forms, reports, logs, & records</li>
                <li>knowledge transfer</li>
              </ul>
            </div>
          </div>

          <div class="department-box it">
            <div class="department-header">it</div>
            <div class="department-content">
              <div class="department-title">it</div>
              <ul>
                <li>customer training</li>
                <li>meeting with clients</li>
                <li>project site survey</li>
                <li>plan and implement projects</li>
                <li>help define project scope, goals and deliverables</li>
                <li>define tasks and required resources</li>
                <li>project and project team consultation</li>
                <li>send emails to client after task completion</li>
                <li>knowledge transfer</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Helper/Laborer Section -->
        <div class="helper-section">
          <div class="department-box helper-box">
            <div class="department-header">helper / laborer</div>
            <div class="department-content">
              <div class="department-title">helper / laborer</div>
              <ul>
                <li>assists technicians</li>
                <li>cleans and prepares installation sites</li>
                <li>removes debris and possible hazards</li>
                <li>loads and unloads materials</li>
                <li>takes apart and sets up scaffolding</li>
                <li>structures construction sites</li>
                <li>digging trenches</li>
                <li>
                  operating hand tools, including hoists, saws, drills, steel
                  saws, & welding equipment
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision Section -->
  <section id="mission-vision" class="about-section">
    <div class="section-container">
      <h2 class="section-title">mission & vision</h2>
      <div class="mission-vision-grid">
        <div class="mission-box">
          <h3>our mission</h3>
          <p>
            to provide comprehensive, reliable, and innovative security
            solutions that protect our clients' assets, ensuring peace of mind
            through cutting-edge technology and exceptional service delivery.
          </p>
        </div>
        <div class="vision-box">
          <h3>our vision</h3>
          <p>
            to be the leading security systems provider in the region,
            recognized for our technical expertise, customer-centric approach,
            and commitment to advancing security technology solutions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section id="why-choose-us" class="about-section">
    <div class="section-container">
      <h2 class="section-title">why choose sss</h2>
      <div class="why-choose-grid">
        <div class="feature-item">
          <div class="feature-icon-text">expert installation</div>
          <h3>expert installation</h3>
          <p>
            certified professionals with years of experience in security system
            installation and maintenance.
          </p>
        </div>
        <div class="feature-item">
          <div class="feature-icon-text">comprehensive solutions</div>
          <h3>comprehensive solutions</h3>
          <p>
            complete range of security services from design and installation to
            ongoing maintenance and support.
          </p>
        </div>
        <div class="feature-item">
          <div class="feature-icon-text">latest technology</div>
          <h3>latest technology</h3>
          <p>
            cutting-edge security systems and smart technology integration for
            modern protection needs.
          </p>
        </div>
        <div class="feature-item">
          <div class="feature-icon-text">24/7 support</div>
          <h3>24/7 support</h3>
          <p>
            round-the-clock technical support and emergency response services
            for complete peace of mind.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* About Hero */
  .about-hero {
    height: 60vh;
    background:
      linear-gradient(
        180deg,
        rgba(11, 31, 51, 0.8) 0%,
        rgba(11, 31, 51, 0.62) 100%
      ),
      linear-gradient(
        115deg,
        rgba(0, 173, 231, 0.25) 0%,
        rgba(26, 54, 93, 0.35) 100%
      ),
      url("/images/upgrade/about-hero.jpg") center center / cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 2rem;
  }

  .hero-title {
    font-size: 4rem;
    font-weight: 200;
    color: #fff;
    margin-bottom: 2rem;
    text-transform: lowercase;
    letter-spacing: -1px;
    line-height: 1.1;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-size: 1.3rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    text-transform: lowercase;
    letter-spacing: 0.5px;
    max-width: 900px;
    line-height: 1.8;
  }

  /* About Navigation */
  .about-navigation {
    background-color: #fff;
    padding: 2rem 0;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
  }

  .about-nav {
    display: flex;
    justify-content: center;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .about-nav-link {
    color: #6f7074;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0.5px;
    padding: 1rem 2rem;
    border-radius: 30px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .about-nav-link:hover,
  .about-nav-link.active {
    color: #fff;
    background: linear-gradient(90deg, #00ade7, #4abdea);
    border-color: #00ade7;
    box-shadow: 0 2px 8px rgba(0, 173, 231, 0.08);
  }

  /* About Sections */
  .about-section {
    padding: 6rem 0;
    background-color: #f8fafc;
  }

  .about-section:nth-child(even) {
    background: linear-gradient(135deg, #e6f8fd 0%, #fff 100%);
  }

  .section-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Brand tagline band */
  .tagline-band {
    background: linear-gradient(115deg, #00ade7 0%, #1a365d 100%);
    padding: 4.5rem 0;
  }

  .brand-quote {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2.5rem;
    text-align: center;
    color: #fff;
    font-size: 2rem;
    font-weight: 300;
    line-height: 1.45;
    text-transform: lowercase;
    letter-spacing: -0.5px;
  }

  .brand-quote .quote-mark {
    display: block;
    font-size: 4.5rem;
    line-height: 0.4;
    margin-bottom: 1.25rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .brand-quote {
      font-size: 1.4rem;
      padding: 0 1.25rem;
    }
  }

  .section-title {
    font-size: 3rem;
    font-weight: 700;
    color: #00ade7;
    text-transform: lowercase;
    letter-spacing: -1px;
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-subtitle {
    font-size: 1.2rem;
    font-weight: 400;
    color: #6f7074;
    text-transform: lowercase;
    text-align: center;
    margin-bottom: 4rem;
  }

  /* Company Overview */
  .overview-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .overview-text .lead-text {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.8;
    color: #222;
    margin-bottom: 2rem;
  }

  .overview-text p {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.7;
    color: #444;
    margin-bottom: 3rem;
  }

  .key-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-item {
    text-align: center;
    padding: 2rem;
    background: #fff;
    border-radius: 12px;
    border: 1.5px solid #9e9a99;
    box-shadow: 0 2px 12px rgba(0, 173, 231, 0.04);
  }

  .stat-item h3 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #00ade7;
    margin-bottom: 0.5rem;
  }

  .stat-item p {
    font-size: 1rem;
    font-weight: 400;
    color: #6f7074;
    text-transform: lowercase;
    margin: 0;
  }

  .overview-image {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .overview-image img {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  /* Company Structure — connected hierarchy diagram */
  /* `.about-section.company-structure-section` to beat `.about-section:nth-child(even)` */
  .about-section.company-structure-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 18% 0%,
        rgba(0, 173, 231, 0.18),
        transparent 42%
      ),
      radial-gradient(
        circle at 85% 100%,
        rgba(63, 183, 233, 0.12),
        transparent 45%
      ),
      linear-gradient(135deg, #0b1f33 0%, #1e293b 100%);
  }

  .company-structure-section .section-title {
    color: #fff;
  }

  .company-structure-section .section-subtitle {
    color: rgba(255, 255, 255, 0.72);
  }

  .structure-container {
    max-width: 1600px;
    margin: 0 auto;
    position: relative;
  }

  /* Cyan connector spine between tiers */
  .division-manager,
  .departments-grid {
    position: relative;
  }

  .division-manager::before,
  .departments-grid::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -4rem;
    transform: translateX(-50%);
    width: 2px;
    height: 4rem;
    background: linear-gradient(180deg, rgba(0, 173, 231, 0), #00ade7);
  }

  .division-manager::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -4rem;
    transform: translateX(-50%);
    width: 2px;
    height: 4rem;
    background: linear-gradient(180deg, #00ade7, rgba(0, 173, 231, 0));
  }

  .top-level {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .entity-box,
  .manager-box,
  .department-box {
    position: relative;
    background: rgba(255, 255, 255, 0.97);
    border: 1px solid rgba(0, 173, 231, 0.22);
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.28);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .entity-box {
    padding: 2rem;
    text-align: center;
  }

  .entity-box:hover,
  .manager-box:hover,
  .department-box:hover {
    transform: translateY(-6px);
    border-color: #00ade7;
    box-shadow: 0 20px 45px rgba(0, 173, 231, 0.28);
  }

  /* glowing node dot on the entity cards */
  .entity-box::before {
    content: "";
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #00ade7;
    box-shadow: 0 0 0 4px rgba(0, 173, 231, 0.22);
  }

  .entity-box h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #00ade7;
    text-transform: lowercase;
    margin-bottom: 1rem;
  }

  .entity-box p {
    font-size: 0.9rem;
    color: #475569;
    text-transform: lowercase;
    line-height: 1.6;
  }

  .division-manager {
    margin-bottom: 4rem;
  }

  .manager-box {
    padding: 3rem;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, #ffffff 0%, #eaf8fe 100%);
    border-color: #00ade7;
  }

  .manager-box h3 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a365d;
    text-transform: lowercase;
    margin-bottom: 2.2rem;
    position: relative;
    display: inline-block;
  }

  .manager-box h3::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -0.7rem;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, #00ade7, #3fb7e9);
  }

  .manager-box ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 2rem;
  }

  .manager-box li {
    font-size: 0.95rem;
    color: #475569;
    text-transform: lowercase;
    padding: 0.4rem 0 0.4rem 1.4rem;
    position: relative;
    text-align: left;
  }

  .manager-box li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #00ade7;
  }

  .departments-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .department-box {
    overflow: hidden;
  }

  .department-header {
    background: linear-gradient(135deg, #00ade7, #3fb7e9);
    color: #fff;
    padding: 1.1rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: lowercase;
    text-align: center;
    letter-spacing: 0.3px;
  }

  .department-content {
    padding: 2rem;
  }

  .department-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a365d;
    text-transform: lowercase;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .department-box ul {
    list-style: none;
    padding: 0;
  }

  .department-box li {
    font-size: 0.85rem;
    color: #475569;
    text-transform: lowercase;
    padding: 0.4rem 0 0.4rem 1.2rem;
    border-bottom: 1px solid #eef2f5;
    position: relative;
  }

  .department-box li::before {
    content: "\203A";
    position: absolute;
    left: 0;
    color: #00ade7;
    font-weight: 700;
  }

  .department-box li:last-child {
    border-bottom: none;
  }

  .helper-section {
    display: flex;
    justify-content: center;
  }

  .helper-box {
    max-width: 500px;
  }

  /* Mission & Vision */
  .mission-vision-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .mission-box,
  .vision-box {
    background: #fff;
    border: 1.5px solid #9e9a99;
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0, 173, 231, 0.04);
  }

  .mission-box h3,
  .vision-box h3 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #00ade7;
    text-transform: lowercase;
    margin-bottom: 2rem;
  }

  .mission-box p,
  .vision-box p {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.7;
    color: #444;
    text-transform: lowercase;
  }

  /* Why Choose Us */
  .why-choose-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .feature-item {
    background: #fff;
    border: 1.5px solid #00ade7;
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 2px 12px rgba(0, 173, 231, 0.04);
  }

  .feature-item:hover {
    background: #e6f8fd;
    border-color: #4abdea;
    transform: translateY(-5px);
    box-shadow: 0 8px 24px rgba(0, 173, 231, 0.1);
  }

  .feature-icon-text {
    display: inline-block;
    background: linear-gradient(90deg, #4abdea, #3fb7e9);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    box-shadow: 0 1px 4px rgba(0, 173, 231, 0.08);
  }

  .feature-item h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #00ade7;
    text-transform: lowercase;
    margin-bottom: 1rem;
  }

  .feature-item p {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: #444;
    text-transform: lowercase;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .about-nav {
      gap: 2rem;
      flex-wrap: wrap;
    }

    .overview-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .key-stats {
      grid-template-columns: repeat(3, 1fr);
    }

    .top-level {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .departments-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .manager-box ul {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .about-hero {
      height: 60vh;
    }

    .about-section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .about-nav {
      gap: 1rem;
    }

    .about-nav-link {
      padding: 0.8rem 1.5rem;
      font-size: 0.9rem;
    }

    .key-stats {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .departments-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .mission-vision-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .why-choose-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .department-content {
      padding: 1.5rem;
    }

    .manager-box {
      padding: 2rem;
    }

    .mission-box,
    .vision-box,
    .feature-item {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .about-hero {
      height: 50vh;
    }

    .about-nav {
      flex-direction: column;
      gap: 0.5rem;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .overview-image img {
      height: 250px;
    }

    .stat-item h3 {
      font-size: 2rem;
    }
  }

  /* Smooth Scrolling */
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  // Smooth navigation scroll and active link updating
  document.addEventListener("DOMContentLoaded", function () {
    const navLinks = document.querySelectorAll(".about-nav-link");
    const sections = document.querySelectorAll(".about-section");

    navLinks.forEach((link) => {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        const targetId = this.getAttribute("href").substring(1);
        const targetSection = document.getElementById(targetId);

        if (targetSection) {
          const offsetTop = targetSection.offsetTop - 100;
          window.scrollTo({
            top: offsetTop,
            behavior: "smooth",
          });
        }

        // Update active link
        navLinks.forEach((l) => l.classList.remove("active"));
        this.classList.add("active");
      });
    });

    // Update active link via IntersectionObserver (no per-scroll layout reads)
    if ("IntersectionObserver" in window && sections.length) {
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.getAttribute("id");
            navLinks.forEach((link) => {
              link.classList.toggle(
                "active",
                link.getAttribute("href") === "#" + id
              );
            });
          });
        },
        { rootMargin: "-45% 0px -50% 0px", threshold: 0 }
      );
      sections.forEach((section) => sectionObserver.observe(section));
    }
  });
</script>
