---
import Layout from "../layouts/Layout.astro";

// Import base path for proper navigation - ensure it ends with /
const baseUrl = import.meta.env.BASE_URL;
const base =
  baseUrl === "" ? "/" : baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";

// ---------------------------------------------------------------------------
// Brand taxonomy — single source of truth for the partners page.
// Each category renders as a full-width "themed band" (a darkened, brand-tinted
// photo background) with the brand logos shown on frosted-glass chips on top.
// To add / move / remove a brand later, just edit this array.
// ---------------------------------------------------------------------------
const categories = [
  {
    id: "av",
    title: "audio visual",
    blurb: "world-class sound, video walls & room control",
    bg: "images/upgrade/service-centralization.jpg",
    brands: [
      { name: "Crestron", logo: "images/logos/crestron-logo.svg", featured: true },
      { name: "Extron", logo: "images/logos/extron.png" },
      { name: "AMX by HARMAN", logo: "images/logos/amx.png" },
      { name: "Q-SYS", logo: "images/logos/qsys.svg" },
      { name: "Biamp", logo: "images/logos/biamp.png" },
      { name: "Shure", logo: "images/logos/shure-1.svg", featured: true },
      { name: "Sennheiser", logo: "images/logos/sennheiser.svg" },
      { name: "Bose Professional", logo: "images/logos/bose-professional.svg" },
      { name: "JBL Professional", logo: "images/logos/jbl-1.svg" },
      { name: "Yamaha Pro Audio", logo: "images/logos/yamaha-2-1.svg" },
      { name: "Sony Professional", logo: "images/logos/sony.svg" },
      { name: "LG Business", logo: "images/logos/lg-electronics.svg" },
      { name: "Samsung Display", logo: "images/logos/samsung.svg" },
      { name: "Barco", logo: "images/logos/barco.svg" },
      { name: "Epson", logo: "images/logos/epson-2.svg" },
      { name: "WISI", logo: "images/logos/wisi-group-logo-vector.svg" },
    ],
  },
  {
    id: "network",
    title: "network",
    blurb: "enterprise switching, routing & wireless backbone",
    bg: "images/upgrade/service-wireless.jpg",
    brands: [
      { name: "Cisco Systems", logo: "images/logos/cisco-2.svg", featured: true },
      { name: "Juniper Networks", logo: "images/logos/juniper.svg" },
      { name: "Aruba Networks", logo: "images/logos/aruba.svg", featured: true },
      { name: "Fortinet", logo: "images/logos/fortinet-logo.svg" },
      { name: "Ruckus", logo: "images/logos/ruckus-wireless5995.jpg" },
      { name: "Extreme Networks", logo: "images/logos/extreme-networks.png" },
      { name: "Huawei Enterprise", logo: "images/logos/huawei.svg" },
      { name: "HPE", logo: "images/logos/hpe.svg" },
      { name: "MikroTik", logo: "images/logos/mikrotik.svg" },
      { name: "Ubiquiti", logo: "images/logos/ubiquiti-networks-2016.svg" },
      { name: "TP-Link", logo: "images/logos/tp-link.svg" },
      { name: "Avaya", logo: "images/logos/avaya-35121.svg" },
      { name: "Dell", logo: "images/logos/dell-2.svg" },
      { name: "HP", logo: "images/logos/hp-1.svg" },
    ],
  },
  {
    id: "cabling",
    title: "structured cabling & infrastructure",
    blurb: "copper, fiber & data-center backbone systems",
    bg: "images/upgrade/why-choose.jpg",
    brands: [
      { name: "CommScope", logo: "images/logos/commscope-networking-service.png", featured: true },
      { name: "Panduit", logo: "images/logos/panduit.svg" },
      { name: "Legrand", logo: "images/logos/legrand.svg" },
      { name: "Belden", logo: "images/logos/belden-4.svg" },
      { name: "Corning", logo: "images/logos/corning.svg" },
      { name: "RDM", logo: "images/logos/rdm.svg" },
      { name: "3M", logo: "images/logos/3m-red.svg" },
    ],
  },
  {
    id: "cctv",
    title: "cctv & video surveillance",
    blurb: "ai-powered cameras & video management systems",
    bg: "images/upgrade/service-cctv.jpg",
    brands: [
      { name: "Hikvision", logo: "images/logos/Hikvision-Logo.png", featured: true },
      { name: "Dahua Technology", logo: "images/logos/Dahua_Technology_logo.svg.png" },
      { name: "Axis Communications", logo: "images/logos/OIP.jpeg" },
      { name: "Bosch Security", logo: "images/logos/bosch.svg" },
      { name: "Hanwha Vision", logo: "images/logos/hanwha-4.svg" },
      { name: "Pelco", logo: "images/logos/pelco-by-schneider-electric-vector-logo.png" },
    ],
  },
  {
    id: "access",
    title: "access control",
    blurb: "credentials, biometrics & smart entry systems",
    bg: "images/upgrade/service-locks.jpg",
    brands: [
      { name: "HID Global", logo: "images/logos/hid-global-logo.svg", featured: true },
      { name: "LenelS2", logo: "images/logos/lenels2.png" },
      { name: "Gallagher", logo: "images/logos/gallagher.png" },
      { name: "Genetec", logo: "images/logos/genetec.svg", featured: true },
      { name: "ZKTeco", logo: "images/logos/zkteco-logo-vector.svg" },
      { name: "Tesa", logo: "images/logos/TESA Small Logo - Degrade - PNG.webp" },
      { name: "Salto", logo: "images/logos/SALTO_inspired_access_LOGO.png" },
      { name: "Tyco", logo: "images/logos/tyco-security-products-vector-logo.svg" },
      { name: "FAAC", logo: "images/logos/FAAC-Logo-Black.png" },
      { name: "Yale", logo: "images/logos/Yale_(company)_logo.png" },
      { name: "Kwikset", logo: "images/logos/Kwikset_Logo_JPEG.5c3f58a7c1f19.avif" },
      { name: "Safran Sagem", logo: "images/logos/safran-sagem.svg" },
    ],
  },
  {
    id: "fire",
    title: "fire alarm & life safety",
    blurb: "certified detection & emergency notification",
    bg: "images/upgrade/services-hero.jpg",
    brands: [
      { name: "Honeywell Notifier", logo: "images/logos/honeywell-1.svg", featured: true },
    ],
  },
];

// Hospitality / Guest Room Management System (GRMS) showcase
const grmsBrands = [
  { name: "Crestron Hospitality", logo: "images/logos/crestron-logo.svg" },
  { name: "Honeywell INNCOM", logo: "images/logos/honeywell-1.svg" },
];
// Uniform monoline icons (cyan) — far cleaner than emoji on the dark band.
const I =
  '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">';
const grmsFeatures = [
  {
    icon: `${I}<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><circle cx="15.5" cy="10" r="1.5"/><line x1="6" y1="15.5" x2="10" y2="15.5"/><line x1="14" y1="15.5" x2="18" y2="15.5"/></svg>`,
    label: "guest room controller",
  },
  {
    icon: `${I}<line x1="9.5" y1="18" x2="14.5" y2="18"/><line x1="10.5" y1="21" x2="13.5" y2="21"/><path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.8 1 .9 1.6l.1.6h5.2l.1-.6c.1-.6.4-1.2.9-1.6A6 6 0 0 0 12 3z"/></svg>`,
    label: "lighting control",
  },
  {
    icon: `${I}<path d="M14 14.76V5a2 2 0 1 0-4 0v9.76a4 4 0 1 0 4 0z"/></svg>`,
    label: "hvac control",
  },
  {
    icon: `${I}<rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>`,
    label: "curtain control",
  },
  {
    icon: `${I}<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>`,
    label: "dnd / mur panel",
  },
  {
    icon: `${I}<circle cx="12" cy="12" r="1.8"/><path d="M16.2 7.8a6 6 0 0 1 0 8.4"/><path d="M7.8 16.2a6 6 0 0 1 0-8.4"/><path d="M19 5a10 10 0 0 1 0 14"/><path d="M5 19A10 10 0 0 1 5 5"/></svg>`,
    label: "occupancy sensor",
  },
  {
    icon: `${I}<rect x="2.5" y="5" width="19" height="14" rx="2"/><line x1="2.5" y1="9.5" x2="21.5" y2="9.5"/><line x1="6" y1="14.5" x2="11" y2="14.5"/></svg>`,
    label: "energy-saving key card",
  },
  {
    icon: `${I}<rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><circle cx="7" cy="7.5" r="0.7"/><circle cx="7" cy="16.5" r="0.7"/></svg>`,
    label: "pms integration",
  },
  {
    icon: `${I}<rect x="6" y="2.5" width="12" height="19" rx="2.5"/><line x1="10.5" y1="18.5" x2="13.5" y2="18.5"/></svg>`,
    label: "mobile app control",
  },
];

// Hero stat counters (animated count-up) — numbers derived from the data.
const totalBrands =
  categories.reduce((n, c) => n + c.brands.length, 0) + grmsBrands.length;
const stats = [
  { target: totalBrands, suffix: "+", label: "leading brands" },
  { target: categories.length + 1, suffix: "", label: "solution domains" },
  { target: 100, suffix: "%", label: "genuine & authorized" },
];

// Sticky filter bar — jump/filter to a category.
const filters = [
  { id: "all", label: "all partners" },
  { id: "av", label: "audio visual" },
  { id: "network", label: "network" },
  { id: "cabling", label: "cabling" },
  { id: "cctv", label: "cctv" },
  { id: "access", label: "access" },
  { id: "fire", label: "fire safety" },
  { id: "hospitality", label: "hospitality" },
];
---

<Layout title="Our Partners - SSS Security Solutions">
  <script is:inline>
    // Enable reveal-on-scroll only when motion is allowed; without this class
    // CSS keeps everything visible (so no-JS / reduced-motion still works).
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      document.documentElement.classList.add("anim");
    }
  </script>

  <!-- Partners Hero -->
  <section class="partners-hero">
    <div class="hero-content">
      <h1 class="hero-title">strategic partnerships</h1>
      <p class="hero-subtitle">
        collaborating with the world's leading technology manufacturers across
        audio visual, networking, surveillance, access control and life safety
      </p>
      <div class="hero-stats">
        {
          stats.map((s) => (
            <div class="stat">
              <span
                class="stat-num"
                data-target={s.target}
                data-suffix={s.suffix}
              >
                0{s.suffix}
              </span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true"><span /></div>
  </section>

  <!-- Sticky category filter bar -->
  <nav class="cat-bar" aria-label="filter partner categories">
    <div class="cat-bar-inner">
      {
        filters.map((f) => (
          <button
            class={`cat-pill${f.id === "all" ? " active" : ""}`}
            data-filter={f.id}
            type="button"
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </nav>

  <!-- Themed Brand Bands -->
  {
    categories.map((cat) => (
      <section
        class="brand-band reveal"
        id={cat.id}
        data-cat={cat.id}
        style={`--band-bg: url('${base}${cat.bg}')`}
      >
        <div class="band-inner">
          <div class="band-head">
            <h2 class="band-title">{cat.title}</h2>
            <p class="band-blurb">{cat.blurb}</p>
          </div>
          <div class="chips">
            {cat.brands.map((b, i) => (
              <div
                class={`chip${b.featured ? " featured" : ""}`}
                style={`--i:${i}`}
              >
                <img
                  loading="lazy"
                  decoding="async"
                  src={`${base}${b.logo}`}
                  alt={b.name}
                  title={b.name}
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <!-- Hospitality / GRMS Showcase -->
  <section class="grms reveal" id="hospitality" data-cat="hospitality">
    <div class="grms-inner">
      <div class="grms-head">
        <span class="grms-eyebrow">premium · hospitality</span>
        <h2 class="grms-title">guest room management systems</h2>
        <p class="grms-sub">
          one intelligent system that controls the entire guest room —
          engineered for 5-star hotels & luxury resorts
        </p>
      </div>

      <!-- Smart-room hub: a central GRMS core controlling all 9 capabilities -->
      <div class="smartroom">
        <div class="hub" aria-hidden="true">
          <span class="hub-ring"></span>
          <span class="hub-ring hub-ring-2"></span>
          <div class="hub-core">
            <span class="hub-icon" set:html={`${I}<path d=\"M3 11.5 12 4l9 7.5\"/><path d=\"M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9\"/><path d=\"M9.5 20v-5h5v5\"/></svg>`} />
            <span class="hub-name">grms</span>
            <span class="hub-tag">one system</span>
          </div>
        </div>

        <p class="controls-label">controls every part of the room</p>

        <div class="grms-grid">
          {
            grmsFeatures.map((f, i) => (
              <div class="grms-feature" style={`--i:${i}`}>
                <span class="grms-icon" set:html={f.icon} />
                <span class="grms-label">{f.label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="grms-brands">
        <span class="grms-brands-label">engineered with</span>
        <div class="grms-brands-row">
          {
            grmsBrands.map((b) => (
              <div class="grms-brand-card">
                <img
                  loading="lazy"
                  decoding="async"
                  src={`${base}${b.logo}`}
                  alt={b.name}
                  title={b.name}
                />
                <span>{b.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Partnership Benefits -->
  <section class="partnership-benefits">
    <div class="container">
      <h2 class="section-title">partnership advantages</h2>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="icon-circle"><span class="icon">🏆</span></div>
          <h3 class="benefit-title">certified expertise</h3>
          <p class="benefit-description">
            factory-trained technicians and certified professionals ensuring
            optimal system performance and reliability
          </p>
        </div>
        <div class="benefit-card">
          <div class="icon-circle"><span class="icon">🔧</span></div>
          <h3 class="benefit-title">genuine products</h3>
          <p class="benefit-description">
            authorized distribution of authentic products with full manufacturer
            warranties and technical support
          </p>
        </div>
        <div class="benefit-card">
          <div class="icon-circle"><span class="icon">⚡</span></div>
          <h3 class="benefit-title">latest technology</h3>
          <p class="benefit-description">
            access to cutting-edge innovations and early adoption of new
            technologies in security solutions
          </p>
        </div>
        <div class="benefit-card">
          <div class="icon-circle"><span class="icon">🛠️</span></div>
          <h3 class="benefit-title">comprehensive support</h3>
          <p class="benefit-description">
            dedicated technical support, training programs, and ongoing
            maintenance services from our partners
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ---------- Partners Hero ---------- */
    .partners-hero {
      position: relative;
      height: 64vh;
      background:
        linear-gradient(
          180deg,
          rgba(11, 31, 51, 0.82) 0%,
          rgba(11, 31, 51, 0.66) 100%
        ),
        linear-gradient(
          115deg,
          rgba(0, 173, 231, 0.28) 0%,
          rgba(26, 54, 93, 0.38) 100%
        ),
        url("/images/upgrade/partners-hero.jpg") center center / cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 2rem;
    }

    .hero-title {
      font-size: 4rem;
      font-weight: 200;
      color: #fff;
      margin-bottom: 1.5rem;
      text-transform: lowercase;
      letter-spacing: -1px;
      line-height: 1.1;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.45);
    }

    .hero-subtitle {
      font-size: 1.25rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.72);
      text-transform: lowercase;
      letter-spacing: 0.5px;
      max-width: 880px;
      line-height: 1.8;
      margin: 0 auto;
    }

    /* ---------- Hero stat counters ---------- */
    .hero-stats {
      display: flex;
      gap: 3.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2.6rem;
    }

    .stat {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .stat-num {
      font-size: 2.7rem;
      font-weight: 200;
      color: #fff;
      line-height: 1;
      text-shadow: 0 2px 16px rgba(0, 173, 231, 0.55);
    }

    .stat-label {
      margin-top: 0.55rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: rgba(255, 255, 255, 0.62);
    }

    .hero-scroll {
      position: absolute;
      bottom: 1.4rem;
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-scroll span {
      display: block;
      width: 2px;
      height: 44px;
      background: linear-gradient(rgba(255, 255, 255, 0), #4abdea);
      animation: scrollPulse 1.9s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%,
      100% {
        opacity: 0.2;
        transform: scaleY(0.55);
        transform-origin: top;
      }
      50% {
        opacity: 1;
        transform: scaleY(1);
        transform-origin: top;
      }
    }

    /* ---------- Sticky category filter bar ---------- */
    .cat-bar {
      position: sticky;
      top: 0;
      z-index: 1001;
      background: rgba(8, 20, 33, 0.92);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 173, 231, 0.18);
    }

    .cat-bar-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0.8rem 1rem;
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .cat-pill {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.16);
      color: rgba(255, 255, 255, 0.75);
      font-family: inherit;
      font-size: 0.9rem;
      text-transform: lowercase;
      letter-spacing: 0.3px;
      padding: 0.5rem 1.1rem;
      border-radius: 999px;
      cursor: pointer;
      transition:
        color 0.25s ease,
        border-color 0.25s ease,
        background 0.25s ease,
        box-shadow 0.25s ease;
    }

    .cat-pill:hover {
      color: #fff;
      border-color: rgba(0, 173, 231, 0.6);
    }

    .cat-pill.active {
      background: linear-gradient(135deg, #00ade7, #3fb7e9);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 4px 16px rgba(0, 173, 231, 0.4);
    }

    .cat-hidden {
      display: none !important;
    }

    /* ---------- Scroll reveal (only active under .anim) ---------- */
    .anim .reveal .band-head,
    .anim .reveal .grms-head,
    .anim .reveal .smartroom,
    .anim .reveal .grms-brands {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 0.6s ease,
        transform 0.6s ease;
    }

    .anim .reveal.is-visible .band-head,
    .anim .reveal.is-visible .grms-head,
    .anim .reveal.is-visible .smartroom,
    .anim .reveal.is-visible .grms-brands {
      opacity: 1;
      transform: none;
    }

    .anim .reveal .chip {
      opacity: 0;
      transform: translateY(24px);
    }

    .anim .reveal.is-visible .chip {
      opacity: 1;
      transform: none;
      transition:
        opacity 0.5s ease,
        transform 0.5s ease;
      transition-delay: calc(var(--i, 0) * 45ms);
    }

    .anim .reveal.is-visible .chip:hover {
      transform: translateY(-7px);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
      transition-delay: 0s;
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-scroll span,
      .hub-ring {
        animation: none;
      }
    }

    /* ---------- Themed Brand Bands ---------- */
    .brand-band {
      position: relative;
      padding: 5rem 2rem;
      background-image:
        linear-gradient(
          135deg,
          rgba(11, 31, 51, 0.93) 0%,
          rgba(8, 46, 71, 0.84) 55%,
          rgba(0, 80, 115, 0.8) 100%
        ),
        var(--band-bg);
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    /* subtle alternating tint so adjacent bands read as distinct */
    .brand-band:nth-child(even) {
      background-image:
        linear-gradient(
          135deg,
          rgba(8, 46, 71, 0.86) 0%,
          rgba(11, 31, 51, 0.93) 55%,
          rgba(26, 54, 93, 0.84) 100%
        ),
        var(--band-bg);
    }

    .band-inner {
      max-width: 1300px;
      margin: 0 auto;
    }

    .band-head {
      margin-bottom: 2.5rem;
    }

    .band-title {
      font-size: 2.2rem;
      font-weight: 300;
      color: #fff;
      text-transform: lowercase;
      letter-spacing: -0.5px;
      margin: 0 0 0.5rem;
      position: relative;
      display: inline-block;
    }

    .band-title::after {
      content: "";
      position: absolute;
      bottom: -0.7rem;
      left: 0;
      width: 64px;
      height: 2px;
      background: linear-gradient(90deg, #00ade7, #4abdea);
    }

    .band-blurb {
      margin: 1.2rem 0 0;
      font-size: 1.05rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.62);
      text-transform: lowercase;
      letter-spacing: 0.3px;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 1.1rem;
    }

    .chip {
      background: rgba(255, 255, 255, 0.94);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      border-radius: 14px;
      width: 168px;
      height: 96px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.4rem;
      box-shadow: 0 10px 26px rgba(0, 0, 0, 0.28);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
    }

    .chip img {
      max-width: 100%;
      max-height: 56px;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .chip:hover {
      transform: translateY(-7px);
      box-shadow: 0 18px 38px rgba(0, 173, 231, 0.4);
    }

    .chip.featured {
      box-shadow:
        0 0 0 2px #00ade7,
        0 10px 26px rgba(0, 0, 0, 0.28);
    }

    .chip.featured:hover {
      box-shadow:
        0 0 0 2px #00ade7,
        0 18px 38px rgba(0, 173, 231, 0.45);
    }

    /* ---------- Hospitality / GRMS ---------- */
    .grms {
      position: relative;
      padding: 6rem 2rem;
      background-image:
        linear-gradient(
          135deg,
          rgba(7, 18, 31, 0.95) 0%,
          rgba(11, 31, 51, 0.9) 100%
        ),
        url("/images/upgrade/project-smarthome.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    .grms-inner {
      max-width: 1100px;
      margin: 0 auto;
      text-align: center;
    }

    .grms-eyebrow {
      display: inline-block;
      font-size: 0.8rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #4abdea;
      margin-bottom: 1rem;
    }

    .grms-title {
      font-size: 2.6rem;
      font-weight: 200;
      color: #fff;
      text-transform: lowercase;
      letter-spacing: -0.5px;
      margin: 0 0 1rem;
    }

    .grms-sub {
      font-size: 1.15rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.68);
      text-transform: lowercase;
      line-height: 1.8;
      max-width: 760px;
      margin: 0 auto 3rem;
    }

    /* Smart-room hub */
    .smartroom {
      margin: 0 auto;
    }

    .hub {
      position: relative;
      width: 150px;
      height: 150px;
      margin: 0 auto 2.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hub-core {
      position: relative;
      z-index: 2;
      width: 132px;
      height: 132px;
      border-radius: 50%;
      background: radial-gradient(circle at 32% 28%, #0a4d6b, #07283a 75%);
      border: 1px solid rgba(0, 173, 231, 0.5);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      box-shadow:
        0 0 42px rgba(0, 173, 231, 0.45),
        inset 0 0 22px rgba(0, 173, 231, 0.18);
    }

    .hub-icon {
      display: inline-flex;
      color: #4abdea;
    }

    .hub-icon svg {
      width: 34px;
      height: 34px;
    }

    .hub-name {
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: 2px;
      color: #fff;
      text-transform: uppercase;
    }

    .hub-tag {
      font-size: 0.6rem;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.55);
      text-transform: uppercase;
    }

    .hub-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(0, 173, 231, 0.45);
      animation: hubPulse 3s ease-out infinite;
    }

    .hub-ring-2 {
      animation-delay: 1.5s;
    }

    @keyframes hubPulse {
      0% {
        transform: scale(0.82);
        opacity: 0.85;
      }
      100% {
        transform: scale(1.85);
        opacity: 0;
      }
    }

    .controls-label {
      text-align: center;
      text-transform: lowercase;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.95rem;
      margin: 0 0 2rem;
    }

    .grms-brands {
      margin-top: 3.5rem;
      text-align: center;
    }

    .grms-brands-label {
      display: block;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 1.2rem;
    }

    .grms-brands-row {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .grms-brand-card {
      background: rgba(255, 255, 255, 0.96);
      border-radius: 16px;
      padding: 1.6rem 2.2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
      min-width: 220px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.32);
      border: 1px solid rgba(0, 173, 231, 0.35);
    }

    .grms-brand-card img {
      max-height: 48px;
      max-width: 170px;
      object-fit: contain;
    }

    .grms-brand-card span {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #1a365d;
      font-weight: 500;
    }

    .grms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.2rem;
      max-width: 980px;
      margin: 0 auto;
    }

    .grms-feature {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 12px;
      padding: 1.4rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.7rem;
      transition:
        transform 0.3s ease,
        background 0.3s ease,
        border-color 0.3s ease;
    }

    .grms-feature:hover {
      transform: translateY(-5px);
      background: rgba(0, 173, 231, 0.12);
      border-color: rgba(0, 173, 231, 0.5);
    }

    .grms-icon {
      display: inline-flex;
      color: #4abdea;
    }

    .grms-icon svg {
      width: 30px;
      height: 30px;
    }

    .grms-feature:hover .grms-icon {
      color: #00ade7;
    }

    .grms-label {
      font-size: 0.95rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.85);
      text-transform: lowercase;
      letter-spacing: 0.3px;
    }

    /* ---------- Partnership Benefits ---------- */
    .partnership-benefits {
      background: linear-gradient(135deg, #e6f8fd 0%, #fff 100%);
      padding: 6rem 0;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .section-title {
      font-size: 3rem;
      font-weight: 300;
      color: #00ade7;
      text-transform: lowercase;
      letter-spacing: -1px;
      text-align: center;
      margin-bottom: 4rem;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .benefit-card {
      background: #fff;
      border: 1.5px solid #00ade7;
      border-radius: 16px;
      padding: 2.5rem;
      text-align: center;
      transition: all 0.4s ease;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    }

    .benefit-card:hover {
      background: #f4fbfe;
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(0, 173, 231, 0.1);
    }

    .icon-circle {
      width: 76px;
      height: 76px;
      background: linear-gradient(135deg, #4abdea, #3fb7e9);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.6rem;
      box-shadow: 0 2px 8px rgba(0, 173, 231, 0.1);
    }

    .icon {
      font-size: 1.9rem;
    }

    .benefit-title {
      font-size: 1.35rem;
      font-weight: 700;
      color: #222;
      text-transform: lowercase;
      letter-spacing: -0.5px;
      margin-bottom: 1rem;
    }

    .benefit-description {
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.7;
      color: #444;
      text-transform: lowercase;
    }

    /* ---------- Responsive ---------- */
    @media (max-width: 768px) {
      .partners-hero {
        height: 52vh;
      }
      .hero-title {
        font-size: 2.5rem;
      }
      .hero-subtitle {
        font-size: 1.1rem;
      }
      .brand-band,
      .grms {
        padding: 4rem 1.25rem;
        background-attachment: scroll;
      }
      .band-title {
        font-size: 1.8rem;
      }
      .chips {
        gap: 0.8rem;
      }
      .chip {
        width: calc(50% - 0.4rem);
        height: 84px;
        padding: 0.9rem 1rem;
      }
      .chip img {
        max-height: 46px;
      }
      .grms-title {
        font-size: 2rem;
      }
      .section-title {
        font-size: 2rem;
      }
    }

    @media (max-width: 480px) {
      .chip {
        height: 76px;
      }
      .chip img {
        max-height: 40px;
      }
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Hide any logo that fails to load (no empty chips).
      const hideBroken = (img: HTMLImageElement) => {
        const c = img.closest(".chip, .grms-brand-card");
        if (c) (c as HTMLElement).style.display = "none";
      };
      document
        .querySelectorAll<HTMLImageElement>(".chip img, .grms-brand-card img")
        .forEach((img) => {
          if (img.complete && img.naturalWidth === 0) hideBroken(img);
          else img.addEventListener("error", () => hideBroken(img));
        });

      // 2. Reveal sections (and their staggered chips) on scroll.
      const reveals = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        reveals.forEach((r) => io.observe(r));
      } else {
        reveals.forEach((r) => r.classList.add("is-visible"));
      }

      // 3. Count-up the hero stats when they scroll into view.
      const runCount = (node: HTMLElement) => {
        const target = parseInt(node.dataset.target || "0", 10);
        const suffix = node.dataset.suffix || "";
        const dur = 1400;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          node.textContent = Math.floor(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
          else node.textContent = target + suffix;
        };
        requestAnimationFrame(tick);
      };
      const nums = document.querySelectorAll<HTMLElement>(".stat-num");
      if (nums.length && "IntersectionObserver" in window) {
        const sObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                runCount(e.target as HTMLElement);
                sObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.6 }
        );
        nums.forEach((n) => sObs.observe(n));
      }

      // 4. Category filter / jump.
      const pills = document.querySelectorAll<HTMLElement>(".cat-pill");
      const bands = document.querySelectorAll<HTMLElement>("[data-cat]");
      pills.forEach((pill) => {
        pill.addEventListener("click", () => {
          const f = pill.dataset.filter;
          pills.forEach((x) => x.classList.toggle("active", x === pill));
          bands.forEach((b) => {
            const show = f === "all" || b.dataset.cat === f;
            b.classList.toggle("cat-hidden", !show);
          });
          if (f && f !== "all") {
            const el = document.getElementById(f);
            if (el) {
              const y = el.getBoundingClientRect().top + window.scrollY - 64;
              window.scrollTo({ top: y, behavior: "smooth" });
            }
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        });
      });
    });
  </script>
</Layout>
