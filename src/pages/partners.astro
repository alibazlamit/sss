---
import Layout from "../layouts/Layout.astro";

// Import base path for proper navigation - ensure it ends with /
const baseUrl = import.meta.env.BASE_URL;
const base =
  baseUrl === "" ? "/" : baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";

// Brand logos are pre-normalized (flattened to white, auto-trimmed, sized
// consistently) into images/logos/norm/<name>.png so every card looks uniform.
const normLogo = (p) =>
  "images/logos/norm/" + p.split("/").pop().replace(/\.[^.]+$/, "") + ".png";

// ---------------------------------------------------------------------------
// Brand taxonomy — single source of truth for the partners page.
// Rendered as an interactive showcase: dark cards that light up (white -> full
// colour) and tilt in 3D on hover, under a cursor-following spotlight.
// To add / move / remove a brand later, just edit this array.
// ---------------------------------------------------------------------------
const categories = [
  {
    id: "av",
    title: "audio visual",
    blurb: "world-class sound, video walls & room control",
    brands: [
      { name: "Extron", logo: "images/logos/extron.png", featured: true },
      { name: "Crestron", logo: "images/logos/crestron-logo.svg", featured: true },
      { name: "AMX by HARMAN", logo: "images/logos/amx.png", featured: true },
      { name: "Biamp", logo: "images/logos/biamp.png", featured: true },
      { name: "Q-SYS", logo: "images/logos/qsys.svg" },
      { name: "Shure", logo: "images/logos/shure-1.svg" },
      { name: "Sennheiser", logo: "images/logos/sennheiser.svg" },
      { name: "Bose Professional", logo: "images/logos/bose-professional.svg" },
      { name: "JBL Professional", logo: "images/logos/jbl-1.svg" },
      { name: "Yamaha Pro Audio", logo: "images/logos/yamaha-2-1.svg" },
      { name: "Sony Professional", logo: "images/logos/sony.svg" },
      { name: "LG Business", logo: "images/logos/lg-electronics.svg" },
      { name: "Samsung Display", logo: "images/logos/samsung.svg" },
      { name: "Barco", logo: "images/logos/barco.svg" },
      { name: "Epson", logo: "images/logos/epson-2.svg" },
      { name: "WISI", logo: "images/logos/wisi-group-logo-vector.svg" },
    ],
  },
  {
    id: "network",
    title: "network",
    blurb: "enterprise switching, routing & wireless backbone",
    brands: [
      { name: "Cisco Systems", logo: "images/logos/cisco-2.svg", featured: true },
      { name: "Juniper Networks", logo: "images/logos/juniper.png" },
      { name: "Aruba Networks", logo: "images/logos/aruba.svg", featured: true },
      { name: "Fortinet", logo: "images/logos/fortinet-logo.svg" },
      { name: "Ruckus", logo: "images/logos/ruckus.svg" },
      { name: "Extreme Networks", logo: "images/logos/extreme-networks.png" },
      { name: "Huawei Enterprise", logo: "images/logos/huawei.png" },
      { name: "HPE", logo: "images/logos/hpe.svg" },
      { name: "MikroTik", logo: "images/logos/mikrotik.svg" },
      { name: "Ubiquiti", logo: "images/logos/ubiquiti-networks-2016.svg" },
      { name: "TP-Link", logo: "images/logos/tp-link.svg" },
      { name: "Avaya", logo: "images/logos/avaya-35121.svg" },
      { name: "Dell", logo: "images/logos/dell-2.svg" },
      { name: "HP", logo: "images/logos/hp-1.svg" },
    ],
  },
  {
    id: "cabling",
    title: "structured cabling & infrastructure",
    blurb: "copper, fiber & data-center backbone systems",
    brands: [
      { name: "CommScope", logo: "images/logos/commscope-networking-service.png", featured: true },
      { name: "Panduit", logo: "images/logos/panduit.svg" },
      { name: "Legrand", logo: "images/logos/legrand.svg" },
      { name: "Belden", logo: "images/logos/belden-4.svg" },
      { name: "Corning", logo: "images/logos/corning.svg" },
      { name: "RDM", logo: "images/logos/rdm.svg" },
      { name: "3M", logo: "images/logos/3m-red.svg" },
    ],
  },
  {
    id: "cctv",
    title: "cctv & video surveillance",
    blurb: "ai-powered cameras & video management systems",
    brands: [
      { name: "Hikvision", logo: "images/logos/Hikvision-Logo.png", featured: true },
      { name: "Dahua Technology", logo: "images/logos/Dahua_Technology_logo.svg.png" },
      { name: "Axis Communications", logo: "images/logos/axis.svg" },
      { name: "Bosch Security", logo: "images/logos/bosch.png" },
      { name: "Hanwha Vision", logo: "images/logos/hanwha-4.svg" },
      { name: "Pelco", logo: "images/logos/pelco-by-schneider-electric-vector-logo.png" },
    ],
  },
  {
    id: "access",
    title: "access control",
    blurb: "credentials, biometrics & smart entry systems",
    brands: [
      { name: "HID Global", logo: "images/logos/hid-global-logo.svg", featured: true },
      { name: "LenelS2", logo: "images/logos/lenels2.png" },
      { name: "Gallagher", logo: "images/logos/gallagher.png" },
      { name: "Genetec", logo: "images/logos/genetec.svg", featured: true },
      { name: "ZKTeco", logo: "images/logos/zkteco-logo-vector.svg" },
      { name: "Tesa", logo: "images/logos/TESA Small Logo - Degrade - PNG.webp" },
      { name: "Salto", logo: "images/logos/SALTO_inspired_access_LOGO.png" },
      { name: "Tyco", logo: "images/logos/tyco-security-products-vector-logo.svg" },
      { name: "FAAC", logo: "images/logos/FAAC-Logo-Black.png" },
      { name: "Yale", logo: "images/logos/Yale_(company)_logo.png" },
      { name: "Kwikset", logo: "images/logos/Kwikset_Logo_JPEG.5c3f58a7c1f19.avif" },
      { name: "Safran Sagem", logo: "images/logos/safran-sagem.svg" },
    ],
  },
  {
    id: "fire",
    title: "fire alarm & life safety",
    blurb: "certified detection & emergency notification",
    brands: [
      { name: "Honeywell Notifier", logo: "images/logos/honeywell-1.svg", featured: true },
    ],
  },
];

// Hospitality / Guest Room Management System (GRMS) showcase
const grmsBrands = [
  { name: "Crestron Hospitality", logo: "images/logos/crestron-logo.svg" },
  { name: "Honeywell INNCOM", logo: "images/logos/honeywell-1.svg" },
];
// Uniform monoline icons (cyan).
const I =
  '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">';
const grmsFeatures = [
  { icon: `${I}<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><circle cx="15.5" cy="10" r="1.5"/><line x1="6" y1="15.5" x2="10" y2="15.5"/><line x1="14" y1="15.5" x2="18" y2="15.5"/></svg>`, label: "guest room controller" },
  { icon: `${I}<line x1="9.5" y1="18" x2="14.5" y2="18"/><line x1="10.5" y1="21" x2="13.5" y2="21"/><path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.8 1 .9 1.6l.1.6h5.2l.1-.6c.1-.6.4-1.2.9-1.6A6 6 0 0 0 12 3z"/></svg>`, label: "lighting control" },
  { icon: `${I}<path d="M14 14.76V5a2 2 0 1 0-4 0v9.76a4 4 0 1 0 4 0z"/></svg>`, label: "hvac control" },
  { icon: `${I}<rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>`, label: "curtain control" },
  { icon: `${I}<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>`, label: "dnd / mur panel" },
  { icon: `${I}<circle cx="12" cy="12" r="1.8"/><path d="M16.2 7.8a6 6 0 0 1 0 8.4"/><path d="M7.8 16.2a6 6 0 0 1 0-8.4"/><path d="M19 5a10 10 0 0 1 0 14"/><path d="M5 19A10 10 0 0 1 5 5"/></svg>`, label: "occupancy sensor" },
  { icon: `${I}<rect x="2.5" y="5" width="19" height="14" rx="2"/><line x1="2.5" y1="9.5" x2="21.5" y2="9.5"/><line x1="6" y1="14.5" x2="11" y2="14.5"/></svg>`, label: "energy-saving key card" },
  { icon: `${I}<rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><circle cx="7" cy="7.5" r="0.7"/><circle cx="7" cy="16.5" r="0.7"/></svg>`, label: "pms integration" },
  { icon: `${I}<rect x="6" y="2.5" width="12" height="19" rx="2.5"/><line x1="10.5" y1="18.5" x2="13.5" y2="18.5"/></svg>`, label: "mobile app control" },
];

const totalBrands =
  categories.reduce((n, c) => n + c.brands.length, 0) + grmsBrands.length;
const stats = [
  { target: totalBrands, suffix: "+", label: "leading brands" },
  { target: categories.length + 1, suffix: "", label: "solution domains" },
  { target: 100, suffix: "%", label: "genuine & authorized" },
];
const filters = [
  { id: "all", label: "all partners" },
  { id: "av", label: "audio visual" },
  { id: "network", label: "network" },
  { id: "cabling", label: "cabling" },
  { id: "cctv", label: "cctv" },
  { id: "access", label: "access" },
  { id: "fire", label: "fire safety" },
  { id: "hospitality", label: "hospitality" },
];
---

<Layout title="Our Partners - SSS Security Solutions">
  <script is:inline>
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      document.documentElement.classList.add("anim");
    }
  </script>

  <div class="px-page">
    <!-- Cursor spotlight -->
    <div class="spotlight" id="spotlight" aria-hidden="true"></div>

    <!-- Hero -->
    <section class="px-hero">
      <div class="px-hero-inner">
        <div class="px-eyebrow">sss · partner network</div>
        <h1 class="px-title">strategic <b>partnerships</b></h1>
        <p class="px-sub">
          the brands behind every system we deliver — audio visual, networking,
          surveillance, access control, structured cabling & life safety
        </p>
        <div class="px-stats">
          {
            stats.map((s) => (
              <div class="px-stat">
                <span class="px-stat-num" data-target={s.target} data-suffix={s.suffix}>
                  0{s.suffix}
                </span>
                <span class="px-stat-label">{s.label}</span>
              </div>
            ))
          }
        </div>
        <div class="px-hint">move your cursor — logos light up</div>
      </div>
    </section>

    <!-- Sticky category filter bar -->
    <nav class="cat-bar" aria-label="filter partner categories">
      <div class="cat-bar-inner">
        {
          filters.map((f) => (
            <button
              class={`cat-pill${f.id === "all" ? " active" : ""}`}
              data-filter={f.id}
              type="button"
            >
              {f.label}
            </button>
          ))
        }
      </div>
    </nav>

    <!-- Hospitality / GRMS Showcase (lead) -->
    <section class="grms reveal" id="hospitality" data-cat="hospitality">
      <div class="grms-inner">
        <div class="grms-head">
          <span class="grms-eyebrow">premium · hospitality</span>
          <h2 class="grms-title">guest room management systems</h2>
          <p class="grms-sub">
            one intelligent system that controls the entire guest room —
            engineered for 5-star hotels & luxury resorts
          </p>
        </div>

        <div class="smartroom">
          <div class="hub" aria-hidden="true">
            <span class="hub-ring"></span>
            <span class="hub-ring hub-ring-2"></span>
            <div class="hub-core">
              <span class="hub-icon" set:html={`${I}<path d=\"M3 11.5 12 4l9 7.5\"/><path d=\"M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9\"/><path d=\"M9.5 20v-5h5v5\"/></svg>`} />
              <span class="hub-name">grms</span>
              <span class="hub-tag">one system</span>
            </div>
          </div>

          <p class="controls-label">controls every part of the room</p>

          <div class="grms-grid">
            {
              grmsFeatures.map((f, i) => (
                <div class="grms-feature" style={`--i:${i}`}>
                  <span class="grms-icon" set:html={f.icon} />
                  <span class="grms-label">{f.label}</span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="grms-brands">
          <span class="grms-brands-label">engineered with</span>
          <div class="grms-brands-row">
            {
              grmsBrands.map((b) => (
                <div class="grms-brand-card">
                  <img loading="lazy" decoding="async" src={`${base}${b.logo}`} alt={b.name} title={b.name} />
                  <span>{b.name}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Interactive brand category grids -->
    {
      categories.map((cat) => (
        <section class="px-cat reveal" id={cat.id} data-cat={cat.id}>
          <div class="px-cat-inner">
            <div class="px-cat-head">
              <h2 class="px-cat-title">{cat.title}</h2>
              <p class="px-cat-blurb">{cat.blurb}</p>
            </div>
            <div class="px-grid">
              {cat.brands.map((b, i) => (
                <div class={`px-card${b.featured ? " featured" : ""}`} style={`--i:${i}`}>
                  <span class="px-logo">
                    <img loading="lazy" decoding="async" src={`${base}${normLogo(b.logo)}`} alt={b.name} title={b.name} />
                  </span>
                </div>
              ))}
            </div>
          </div>
        </section>
      ))
    }

    <!-- Partnership Benefits -->
    <section class="px-benefits">
      <div class="px-cat-inner">
        <h2 class="px-cat-title center">partnership advantages</h2>
        <div class="benefits-grid">
          <div class="benefit-card">
            <span class="benefit-icon" set:html={`${I}<path d=\"M8 21h8\"/><path d=\"M12 17v4\"/><path d=\"M7 4h10v5a5 5 0 0 1-10 0z\"/><path d=\"M5 5H3v2a3 3 0 0 0 3 3\"/><path d=\"M19 5h2v2a3 3 0 0 1-3 3\"/></svg>`} />
            <h3>certified expertise</h3>
            <p>factory-trained, certified engineers delivering reliable, standards-compliant systems</p>
          </div>
          <div class="benefit-card">
            <span class="benefit-icon" set:html={`${I}<path d=\"M9 12l2 2 4-4\"/><path d=\"M12 3 4 6v6c0 5 3.5 7.5 8 9 4.5-1.5 8-4 8-9V6z\"/></svg>`} />
            <h3>genuine products</h3>
            <p>authorized distribution of authentic products with full manufacturer warranties</p>
          </div>
          <div class="benefit-card">
            <span class="benefit-icon" set:html={`${I}<path d=\"M13 2 3 14h7l-1 8 10-12h-7z\"/></svg>`} />
            <h3>latest technology</h3>
            <p>early access to cutting-edge innovations across every solution domain</p>
          </div>
          <div class="benefit-card">
            <span class="benefit-icon" set:html={`${I}<path d=\"M14.7 6.3a4 4 0 0 0-5.4 5.4l-6 6 2 2 6-6a4 4 0 0 0 5.4-5.4l-2.3 2.3-2-2z\"/></svg>`} />
            <h3>full support</h3>
            <p>dedicated technical support, training and ongoing maintenance from our partners</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    /* =================== Page shell (dark) =================== */
    .px-page {
      position: relative;
      background:
        radial-gradient(1100px 620px at 78% -6%, rgba(0, 173, 231, 0.16), transparent 60%),
        radial-gradient(900px 560px at 4% 102%, rgba(0, 95, 145, 0.16), transparent 60%),
        #07111d;
      overflow: clip;
    }
    .px-page::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(0, 173, 231, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 173, 231, 0.05) 1px, transparent 1px);
      background-size: 52px 52px;
      -webkit-mask-image: radial-gradient(circle at 50% 22%, #000 0%, transparent 75%);
      mask-image: radial-gradient(circle at 50% 22%, #000 0%, transparent 75%);
      pointer-events: none;
    }

    .spotlight {
      position: fixed;
      inset: 0;
      z-index: 40;
      pointer-events: none;
      mix-blend-mode: screen;
      background: radial-gradient(
        520px circle at var(--mx, 50%) var(--my, 25%),
        rgba(0, 173, 231, 0.13),
        transparent 62%
      );
    }

    /* =================== Hero =================== */
    .px-hero {
      position: relative;
      z-index: 2;
      min-height: 78vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 7rem 2rem 4rem;
    }
    .px-hero-inner { max-width: 900px; }
    .px-eyebrow {
      font-size: 0.78rem;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: #4abdea;
      margin-bottom: 1.4rem;
    }
    .px-title {
      font-size: 4.4rem;
      font-weight: 200;
      line-height: 1.04;
      letter-spacing: -1.5px;
      color: #fff;
      text-transform: lowercase;
      text-shadow: 0 0 50px rgba(0, 173, 231, 0.35);
    }
    .px-title b { font-weight: 600; color: #00ade7; }
    .px-sub {
      margin: 1.6rem auto 0;
      max-width: 680px;
      font-size: 1.12rem;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.6);
      text-transform: lowercase;
    }
    .px-stats {
      display: flex;
      gap: 3.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 3rem;
    }
    .px-stat { display: flex; flex-direction: column; align-items: center; }
    .px-stat-num {
      font-size: 2.8rem;
      font-weight: 200;
      color: #fff;
      line-height: 1;
      text-shadow: 0 0 22px rgba(0, 173, 231, 0.6);
    }
    .px-stat-label {
      margin-top: 0.55rem;
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: rgba(255, 255, 255, 0.55);
    }
    .px-hint {
      margin-top: 3rem;
      font-size: 0.8rem;
      letter-spacing: 1px;
      text-transform: lowercase;
      color: rgba(255, 255, 255, 0.4);
    }

    /* =================== Sticky filter bar =================== */
    .cat-bar {
      position: sticky;
      top: 0;
      z-index: 1001;
      background: rgba(7, 17, 29, 0.85);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      border-top: 1px solid rgba(0, 173, 231, 0.18);
      border-bottom: 1px solid rgba(0, 173, 231, 0.18);
    }
    .cat-bar-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0.8rem 1rem;
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .cat-pill {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.14);
      color: rgba(255, 255, 255, 0.72);
      font-family: inherit;
      font-size: 0.9rem;
      text-transform: lowercase;
      letter-spacing: 0.3px;
      padding: 0.5rem 1.1rem;
      border-radius: 999px;
      cursor: pointer;
      transition: color 0.25s, border-color 0.25s, background 0.25s, box-shadow 0.25s;
    }
    .cat-pill:hover { color: #fff; border-color: rgba(0, 173, 231, 0.6); }
    .cat-pill.active {
      background: linear-gradient(135deg, #00ade7, #3fb7e9);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 4px 18px rgba(0, 173, 231, 0.45);
    }
    .cat-hidden { display: none !important; }

    /* =================== Interactive brand grids =================== */
    .px-cat { position: relative; z-index: 2; padding: 4.2rem 2rem; }
    .px-cat-inner { max-width: 1300px; margin: 0 auto; }
    .px-cat-head { margin-bottom: 2.2rem; }
    .px-cat-title {
      font-size: 2.1rem;
      font-weight: 300;
      color: #fff;
      text-transform: lowercase;
      letter-spacing: -0.5px;
      margin: 0;
      position: relative;
      display: inline-block;
    }
    .px-cat-title.center { display: block; text-align: center; }
    .px-cat-title::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -0.6rem;
      width: 58px;
      height: 2px;
      background: linear-gradient(90deg, #00ade7, #4abdea);
    }
    .px-cat-title.center::after { left: 50%; transform: translateX(-50%); }
    .px-cat-blurb {
      margin: 1.2rem 0 0;
      font-size: 1rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.5);
      text-transform: lowercase;
    }

    .px-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(186px, 1fr));
      gap: 1.1rem;
    }
    .px-card {
      position: relative;
      aspect-ratio: 16 / 10;
      border-radius: 16px;
      padding: 0.5rem;
      background: rgba(255, 255, 255, 0.045);
      border: 1px solid rgba(255, 255, 255, 0.09);
      transform-style: preserve-3d;
      transition:
        transform 0.25s ease,
        border-color 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease;
      will-change: transform;
    }
    .px-logo {
      width: 100%;
      height: 100%;
      border-radius: 12px;
      background: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.85rem 1.15rem;
    }
    .px-logo img {
      max-width: 100%;
      max-height: 50px;
      width: auto;
      height: auto;
      object-fit: contain;
      filter: grayscale(1);
      opacity: 0.85;
      transition: filter 0.3s ease, opacity 0.3s ease;
    }
    .px-card.featured { border-color: rgba(0, 173, 231, 0.5); }
    .px-card.featured .px-logo {
      box-shadow: inset 0 0 0 2px rgba(0, 173, 231, 0.3);
    }
    .px-card:hover {
      border-color: rgba(0, 173, 231, 0.7);
      box-shadow: 0 22px 55px rgba(0, 173, 231, 0.32);
      background: rgba(0, 173, 231, 0.1);
    }
    .px-card:hover .px-logo img { filter: none; opacity: 1; }

    /* =================== Hospitality / GRMS =================== */
    .grms {
      position: relative;
      z-index: 2;
      padding: 5.5rem 2rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .grms-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
    .grms-eyebrow {
      display: inline-block;
      font-size: 0.78rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #4abdea;
      margin-bottom: 1rem;
    }
    .grms-title {
      font-size: 2.5rem;
      font-weight: 200;
      color: #fff;
      text-transform: lowercase;
      letter-spacing: -0.5px;
      margin: 0 0 1rem;
    }
    .grms-sub {
      font-size: 1.1rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.62);
      text-transform: lowercase;
      line-height: 1.8;
      max-width: 720px;
      margin: 0 auto 3rem;
    }
    .hub {
      position: relative;
      width: 150px;
      height: 150px;
      margin: 0 auto 2.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hub-core {
      position: relative;
      z-index: 2;
      width: 132px;
      height: 132px;
      border-radius: 50%;
      background: radial-gradient(circle at 32% 28%, #0a4d6b, #07283a 75%);
      border: 1px solid rgba(0, 173, 231, 0.5);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      box-shadow: 0 0 42px rgba(0, 173, 231, 0.45), inset 0 0 22px rgba(0, 173, 231, 0.18);
    }
    .hub-icon { display: inline-flex; color: #4abdea; }
    .hub-icon svg { width: 34px; height: 34px; }
    .hub-name {
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: 2px;
      color: #fff;
      text-transform: uppercase;
    }
    .hub-tag {
      font-size: 0.6rem;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.55);
      text-transform: uppercase;
    }
    .hub-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(0, 173, 231, 0.45);
      animation: hubPulse 3s ease-out infinite;
    }
    .hub-ring-2 { animation-delay: 1.5s; }
    @keyframes hubPulse {
      0% { transform: scale(0.82); opacity: 0.85; }
      100% { transform: scale(1.85); opacity: 0; }
    }
    .controls-label {
      text-align: center;
      text-transform: lowercase;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.95rem;
      margin: 0 0 2rem;
    }
    .grms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.2rem;
      max-width: 980px;
      margin: 0 auto;
    }
    .grms-feature {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 12px;
      padding: 1.4rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.7rem;
      transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
    }
    .grms-feature:hover {
      transform: translateY(-5px);
      background: rgba(0, 173, 231, 0.12);
      border-color: rgba(0, 173, 231, 0.5);
    }
    .grms-icon { display: inline-flex; color: #4abdea; }
    .grms-feature:hover .grms-icon { color: #00ade7; }
    .grms-label {
      font-size: 0.95rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.85);
      text-transform: lowercase;
    }
    .grms-brands { margin-top: 3.5rem; text-align: center; }
    .grms-brands-label {
      display: block;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 1.2rem;
    }
    .grms-brands-row { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
    .grms-brand-card {
      background: rgba(255, 255, 255, 0.96);
      border-radius: 16px;
      padding: 1.6rem 2.2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
      min-width: 220px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.32);
      border: 1px solid rgba(0, 173, 231, 0.35);
    }
    .grms-brand-card img { max-height: 48px; max-width: 170px; object-fit: contain; }
    .grms-brand-card span {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #1a365d;
      font-weight: 500;
    }

    /* =================== Benefits =================== */
    .px-benefits {
      position: relative;
      z-index: 2;
      padding: 5rem 2rem 6rem;
    }
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.4rem;
      margin-top: 3rem;
    }
    .benefit-card {
      background: rgba(255, 255, 255, 0.035);
      border: 1px solid rgba(255, 255, 255, 0.09);
      border-radius: 16px;
      padding: 2.2rem 1.8rem;
      text-align: center;
      transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    }
    .benefit-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0, 173, 231, 0.5);
      background: rgba(0, 173, 231, 0.06);
    }
    .benefit-icon { display: inline-flex; color: #4abdea; margin-bottom: 1.1rem; }
    .benefit-icon svg { width: 34px; height: 34px; }
    .benefit-card h3 {
      font-size: 1.2rem;
      font-weight: 400;
      color: #fff;
      text-transform: lowercase;
      margin: 0 0 0.7rem;
    }
    .benefit-card p {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.58);
      text-transform: lowercase;
      margin: 0;
    }

    /* =================== Scroll reveal =================== */
    .anim .reveal .px-cat-head,
    .anim .reveal .grms-head,
    .anim .reveal .smartroom,
    .anim .reveal .grms-brands {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .anim .reveal.is-visible .px-cat-head,
    .anim .reveal.is-visible .grms-head,
    .anim .reveal.is-visible .smartroom,
    .anim .reveal.is-visible .grms-brands {
      opacity: 1;
      transform: none;
    }
    .anim .reveal .px-card { opacity: 0; }
    .anim .reveal.is-visible .px-card {
      opacity: 1;
      transition: opacity 0.5s ease;
      transition-delay: calc(var(--i, 0) * 40ms);
    }

    @media (prefers-reduced-motion: reduce) {
      .hub-ring { animation: none; }
    }

    /* =================== Responsive =================== */
    @media (max-width: 768px) {
      .px-hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
      .px-title { font-size: 2.7rem; }
      .px-sub { font-size: 1rem; }
      .px-cat, .grms, .px-benefits { padding: 3.5rem 1.25rem; }
      .px-cat-title { font-size: 1.7rem; }
      .grms-title { font-size: 2rem; }
      .px-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.8rem; }
      .px-card img { max-height: 38px; }
      .spotlight { display: none; }
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Hide broken logos so no empty card is left behind.
      const hide = (img: HTMLImageElement) => {
        const c = img.closest(".px-card, .grms-brand-card");
        if (c) (c as HTMLElement).style.display = "none";
      };
      document
        .querySelectorAll<HTMLImageElement>(".px-card img, .grms-brand-card img")
        .forEach((img) => {
          if (img.complete && img.naturalWidth === 0) hide(img);
          else img.addEventListener("error", () => hide(img));
        });

      // Cursor spotlight.
      const spot = document.getElementById("spotlight");
      if (spot) {
        window.addEventListener(
          "pointermove",
          (e) => {
            spot.style.setProperty("--mx", e.clientX + "px");
            spot.style.setProperty("--my", e.clientY + "px");
          },
          { passive: true }
        );
      }

      // 3D tilt on cards.
      document.querySelectorAll<HTMLElement>(".px-card").forEach((card) => {
        card.addEventListener("pointermove", (e) => {
          const r = card.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          card.style.transform = `perspective(700px) rotateY(${px * 15}deg) rotateX(${-py * 15}deg) translateZ(12px)`;
        });
        card.addEventListener("pointerleave", () => {
          card.style.transform = "";
        });
      });

      // Scroll reveal.
      const reveals = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        reveals.forEach((r) => io.observe(r));
      } else {
        reveals.forEach((r) => r.classList.add("is-visible"));
      }

      // Count-up stats.
      const runCount = (node: HTMLElement) => {
        const target = parseInt(node.dataset.target || "0", 10);
        const suffix = node.dataset.suffix || "";
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / 1400, 1);
          node.textContent = Math.floor((1 - Math.pow(1 - p, 3)) * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
          else node.textContent = target + suffix;
        };
        requestAnimationFrame(tick);
      };
      const nums = document.querySelectorAll<HTMLElement>(".px-stat-num");
      if (nums.length && "IntersectionObserver" in window) {
        const sObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                runCount(e.target as HTMLElement);
                sObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.6 }
        );
        nums.forEach((n) => sObs.observe(n));
      }

      // Category filter / jump.
      const pills = document.querySelectorAll<HTMLElement>(".cat-pill");
      const bands = document.querySelectorAll<HTMLElement>("[data-cat]");
      pills.forEach((pill) => {
        pill.addEventListener("click", () => {
          const f = pill.dataset.filter;
          pills.forEach((x) => x.classList.toggle("active", x === pill));
          bands.forEach((b) => {
            const show = f === "all" || b.dataset.cat === f;
            b.classList.toggle("cat-hidden", !show);
          });
          if (f && f !== "all") {
            const el = document.getElementById(f);
            if (el) {
              const y = el.getBoundingClientRect().top + window.scrollY - 64;
              window.scrollTo({ top: y, behavior: "smooth" });
            }
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        });
      });
    });
  </script>
</Layout>
